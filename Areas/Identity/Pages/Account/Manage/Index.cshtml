@page
@model IndexModel
@{
    ViewData["Title"] = "Meu Perfil";
    Layout = "~/Areas/Identity/Pages/_AuthLayout.cshtml";
}

<div class="auth-card" style="max-width:520px;">
    <div class="auth-header">
        <i class="bi bi-person-circle auth-logo"></i>
        <h1 class="auth-title">Meu Perfil</h1>
        <p class="auth-subtitle">@Model.Username</p>
    </div>

    <partial name="_StatusMessage" for="StatusMessage" />

    <form method="post">
        <div class="mb-3">
            <label class="form-label">Usuário</label>
            <input type="text" class="form-control" value="@Model.Username" disabled />
            <div class="form-text">O nome de usuário não pode ser alterado.</div>
        </div>

        <div class="mb-4">
            <label asp-for="Input.PhoneNumber" class="form-label">Telefone</label>
            <input asp-for="Input.PhoneNumber" class="form-control" placeholder="(11) 99999-9999" />
            <span asp-validation-for="Input.PhoneNumber" class="text-danger small"></span>
        </div>

        <button type="submit" class="btn btn-primary w-100 mb-3">
            <i class="bi bi-check-lg me-2"></i>Salvar alterações
        </button>

        <div class="auth-links">
            <a href="/Identity/Account/Manage/ChangePassword">🔒 Alterar senha</a>
            <span class="text-muted">·</span>
            <a href="/tasks">← Voltar ao app</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}