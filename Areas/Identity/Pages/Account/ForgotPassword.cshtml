@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Esqueci a senha";
    Layout = "~/Areas/Identity/Pages/_AuthLayout.cshtml";
}

<div class="auth-card">
    <div class="auth-header">
        <i class="bi bi-key auth-logo"></i>
        <h1 class="auth-title">Esqueceu a senha?</h1>
        <p class="auth-subtitle">Informe seu email e enviaremos um link para redefinição</p>
    </div>

    <form method="post">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small" role="alert"></div>

        <div class="mb-4">
            <label asp-for="Input.Email" class="form-label">Email</label>
            <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="seu@email.com" />
            <span asp-validation-for="Input.Email" class="text-danger small"></span>
        </div>

        <button type="submit" class="btn btn-primary w-100 mb-3">
            <i class="bi bi-send me-2"></i>Enviar link de redefinição
        </button>

        <div class="auth-links">
            <a href="/Identity/Account/Login">← Voltar ao login</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}