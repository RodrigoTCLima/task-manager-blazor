@page
@model LoginModel
@{
    ViewData["Title"] = "Entrar";
    Layout = "~/Areas/Identity/Pages/_AuthLayout.cshtml";
}

<div class="auth-card">
    <div class="auth-header">
        <i class="bi bi-check2-square auth-logo"></i>
        <h1 class="auth-title">TaskManager</h1>
        <p class="auth-subtitle">Entre na sua conta</p>
    </div>

    <form method="post">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small" role="alert"></div>

        <div class="mb-3">
            <label asp-for="Input.Email" class="form-label">Email</label>
            <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="seu@email.com" />
            <span asp-validation-for="Input.Email" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Input.Password" class="form-label">Senha</label>
            <input asp-for="Input.Password" class="form-control" autocomplete="current-password" placeholder="••••••••" />
            <span asp-validation-for="Input.Password" class="text-danger small"></span>
        </div>

        <div class="mb-3 form-check">
            <input asp-for="Input.RememberMe" class="form-check-input" />
            <label asp-for="Input.RememberMe" class="form-check-label">Lembrar de mim</label>
        </div>

        <button type="submit" class="btn btn-primary w-100 mb-3">
            <i class="bi bi-box-arrow-in-right me-2"></i>Entrar
        </button>

        <div class="auth-links">
            <a href="/Identity/Account/ForgotPassword">Esqueceu a senha?</a>
            <span class="text-muted">·</span>
            <a href="/Identity/Account/Register">Criar conta</a>
            <span class="text-muted">·</span>
            <a href="/Identity/Account/ResendEmailConfirmation">Reenviar confirmação</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}