@{
    var title = ViewData["Title"]?.ToString() ?? "TaskManager";
}
<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@title — TaskManager</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/app.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
            html,
            body {
                height: 100%;
                background: var(--bg-body, #f8f9fa);
                color: var(--text-body, #212529);
                transition: background-color 0.2s ease;
            }

            .auth-wrapper {
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 24px 16px;
                background: var(--bg-body, linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%));
            }

            .auth-card {
                background: var(--bg-card, white);
                border-radius: 16px;
                padding: 40px 36px;
                width: 100%;
                max-width: 420px;
                box-shadow: var(--shadow-card, 0 4px 24px rgba(0, 0, 0, .08));
                border: 1px solid var(--border-color, transparent);
            }

            .auth-title {
                font-size: 1.5rem;
                font-weight: 700;
                color: var(--text-body, #212529);
                margin-bottom: 4px;
            }

            .auth-subtitle {
                color: var(--text-muted, #6c757d);
                font-size: .95rem;
                margin: 0;
            }

            .form-control {
                border-radius: 8px;
                padding: 10px 14px;
                background-color: var(--bg-input, white);
                color: var(--text-body, #212529);
                border-color: var(--border-input, #ced4da);
            }

            .form-control:focus {
                border-color: var(--accent, #198754);
                box-shadow: 0 0 0 3px rgba(25, 135, 84, .15);
                background-color: var(--bg-input, white);
                color: var(--text-body, #212529);
            }

            .btn-primary {
                background: var(--accent, #198754);
                border-color: var(--accent, #198754);
                border-radius: 8px;
                padding: 10px;
                font-weight: 500;
            }

            .btn-primary:hover {
                background: var(--accent-hover, #157347);
                border-color: var(--accent-hover, #157347);
            }

            .auth-links a {
                color: var(--accent, #198754);
                text-decoration: none;
            }
    </style>
    <script>
            (function () {
                const saved = localStorage.getItem('theme');
                if (saved === 'dark' || (!saved && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                    document.documentElement.setAttribute('data-theme', 'dark');
                }
            })();
    </script>
</head>

<body>
    <div class="auth-wrapper">
        @RenderBody()
    </div>

    @await RenderSectionAsync("Scripts", required: false)

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>

</html>