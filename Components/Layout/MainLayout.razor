@using Microsoft.AspNetCore.Components.Authorization
@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <AuthorizeView>
                <Authorized>
                    <span class="navbar-text me-2">Olá, @context.User.Identity?.Name!</span>
                    <a href="/Identity/Account/Manage" class="btn btn-outline-secondary btn-sm me-1">Perfil</a>
                    <form method="post" action="/Identity/Account/Logout" class="d-inline">
                        <AntiforgeryToken />
                        <input type="hidden" name="ReturnUrl" value="/Identity/Account/Login" />
                        <button type="submit" class="btn btn-outline-danger btn-sm">Sair</button>
                    </form>
                </Authorized>
                <NotAuthorized>
                    <a href="/Identity/Account/Register" class="btn btn-outline-primary btn-sm me-1">Cadastrar</a>
                    <a href="/Identity/Account/Login?returnUrl=%2Ftasks" class="btn btn-primary btn-sm">Entrar</a>
                </NotAuthorized>
            </AuthorizeView>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
