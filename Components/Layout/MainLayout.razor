@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using TaskManager.Models
@inherits LayoutComponentBase
@inject IJSRuntime JS
@inject UserManager<ApplicationUser> UserManager

<div class="page" id="app-root">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <AuthorizeView>
                <Authorized>
                    <span class="navbar-text me-2">Olá, @displayName!</span>
                    <a href="/Identity/Account/Manage" class="btn btn-outline-secondary btn-sm me-1">Perfil</a>
                    <form method="post" action="/Identity/Account/Logout" class="d-inline">
                        <AntiforgeryToken />
                        <input type="hidden" name="ReturnUrl" value="/Identity/Account/Login" />
                        <button type="submit" class="btn btn-outline-danger btn-sm">Sair</button>
                    </form>
                </Authorized>
                <NotAuthorized>
                    <a href="/Identity/Account/Register" class="btn btn-outline-primary btn-sm me-1">Cadastrar</a>
                    <a href="/Identity/Account/Login?returnUrl=%2Ftasks" class="btn btn-primary btn-sm">Entrar</a>
                </NotAuthorized>
            </AuthorizeView>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    Ocorreu um erro inesperado.
    <a href="." class="reload">Recarregar</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private string displayName = "";

    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (AuthenticationStateTask != null)
        {
            var authState = await AuthenticationStateTask;
            var userId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

            if (!string.IsNullOrEmpty(userId))
            {
                var user = await UserManager.FindByIdAsync(userId);
                displayName = user?.GetDisplayName() ?? authState.User.Identity?.Name ?? "Usuário";
            }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("themeManager.applyToRoot");
        }
    }
}