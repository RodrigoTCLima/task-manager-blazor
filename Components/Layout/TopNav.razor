@using Microsoft.AspNetCore.Components.Authorization
@rendermode InteractiveServer

<div class="navbar navbar-light bg-light px-4 shadow-sm mb-3">
    <div class="container-fluid">
        <a class="navbar-brand fw-bold" href="/tasks">
            ✅ TaskManager
        </a>
        <AuthorizeView>
            <Authorized>
                <div class="d-flex align-items-center gap-2">
                    <span class="navbar-text">
                        Olá, @context.User.Identity?.Name!
                    </span>
                    <a href="/Identity/Account/Manage" class="btn btn-outline-secondary btn-sm">
                        Perfil
                    </a>
                    <form method="post" action="/Identity/Account/Logout">
                        <AntiforgeryToken />
                        <input type="hidden" name="ReturnUrl" value="/Identity/Account/Login" />
                        <button type="submit" class="btn btn-outline-danger btn-sm">
                            Sair
                        </button>
                    </form>
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="d-flex gap-2">
                    <a href="/Identity/Account/Register" class="btn btn-outline-primary btn-sm">
                        Cadastrar
                    </a>
                    <a href="/Identity/Account/Login?returnUrl=%2Ftasks" class="btn btn-primary btn-sm">
                        Entrar
                    </a>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </div>
</div>
