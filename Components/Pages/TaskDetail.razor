@page "/task/{Id:int}"
@attribute [Authorize]
@using TaskManager.Models
@using TaskManager.Services
@inject TaskService TaskService
@inject NavigationManager Nav
@rendermode InteractiveServer


<PageTitle>Detalhes da Tarefa</PageTitle>

@if (task == null)
{
    <p>Carregando...</p>
}
else
{
    <div class="container py-4" style="max-width: 720px;">

        <!-- Cabeçalho -->
        <div class="d-flex justify-content-between align-items-start mb-3">
            <h3 class="@(task.IsCompleted ? "text-decoration-line-through text-muted" : "")">
                <span class="text-muted me-2 fs-5">#@task.Id</span>@task.Title
            </h3>

            <span class="badge fs-6 @GetPriorityClass(task.Priority)">
                @GetPriorityEmoji(task.Priority) Prioridade @task.Priority
            </span>
        </div>

        <!-- Status -->
        <div class="mb-3 d-flex align-items-center gap-3">
            <div class="form-check form-check-inline">
                <input class="form-check-input" type="checkbox" id="completeMain" checked="@task.IsCompleted"
                       disabled="@hasPendingDeps" @onchange="ToggleMainTask" style="width:1.2rem;height:1.2rem;" />
                <label class="form-check-label fw-bold" for="completeMain">Concluída</label>
            </div>
            @if (hasPendingDeps)
            {
                <span class="text-warning small">⚠️ Dependências pendentes</span>
            }
            @if (task.IsCompleted)
            {
                <span class="badge bg-success">✅ Concluída</span>
            }
            else if (task.DueDate.HasValue && task.DueDate.Value < DateTime.UtcNow)
            {
                <span class="badge bg-danger">🔥 Atrasada</span>
            }
            else
            {
                <span class="badge bg-warning text-dark">⏳ Pendente</span>
            }
            <span class="badge bg-secondary ms-2">🗂️ @task.Category</span>
        </div>


        <!-- Descrição -->
        @if (!string.IsNullOrWhiteSpace(task.Description))
        {
            <div class="card mb-3">
                <div class="card-header fw-bold">📝 Descrição</div>
                <div class="card-body">@task.Description</div>
            </div>
        }

        <!-- Datas -->
        <div class="card mb-3">
            <div class="card-header fw-bold">📅 Datas</div>
            <ul class="list-group list-group-flush">
                <li class="list-group-item d-flex justify-content-between">
                    <span>Criada em</span>
                    <span>@task.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                </li>
                <li class="list-group-item d-flex justify-content-between">
                    <span>Vencimento</span>
                    <span>@(task.DueDate.HasValue ? task.DueDate.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm") :
                    "—")</span>
                    </li>
                    @if (task.HasAlarm && task.AlarmTime.HasValue)
                    {
                        <li class="list-group-item d-flex justify-content-between">
                            <span>⏰ Alarme</span>
                            <span>@task.AlarmTime.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                        </li>
                    }
                </ul>
            </div>

            <!-- Tags -->
            @if (task.Tags?.Any() == true)
            {
                <div class="card mb-3">
                    <div class="card-header fw-bold">🏷️ Tags</div>
                    <div class="card-body d-flex flex-wrap gap-2">
                        @foreach (var tag in task.Tags)
                        {
                            <span class="badge bg-info text-dark">@tag</span>
                        }
                    </div>
                </div>
            }

            <!-- Recorrência -->
            @if (task.IsRecurrent)
            {
                <div class="card mb-3">
                    <div class="card-header fw-bold">🔁 Recorrência</div>
                    <div class="card-body">@task.RecurrencePattern</div>
                </div>
            }

            <!-- Comentários -->
            <div class="card mb-3">
                <div class="card-header fw-bold">💬 Comentários</div>
                <div class="card-body">
                    @if (task.Comments == null || !task.Comments.Any())
                    {
                        <p class="text-muted">Nenhum comentário ainda.</p>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var comment in task.Comments.OrderByDescending(c => c.CreatedAt))
                            {
                                <li class="list-group-item">
                                    <div class="d-flex justify-content-between">
                                        <strong>@comment.AuthorUserId</strong>
                                        <small class="text-muted">@comment.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</small>
                                    </div>
                                    <p class="mb-0 mt-1">@comment.Content</p>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>
            @if (dependencies.Any())
            {
                <div class="card mb-3">
                    <div class="card-header fw-bold">🔗 Depende de</div>
                    <ul class="list-group list-group-flush">
                        @foreach (var dep in dependencies)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <div class="d-flex align-items-center gap-2">
                                    <input type="checkbox" class="form-check-input mt-0" checked="@dep.IsCompleted"
                                           @onchange="() => ToggleDependencyTask(dep.Id)" style="width:1.1rem;height:1.1rem;" />
                                    <a href="/task/@dep.Id" class="text-decoration-none @(dep.IsCompleted ? "text-muted" : "")">
                                        <span class="text-muted me-1 small">#@dep.Id</span>@dep.Title
                                    </a>
                                </div>
                                @if (dep.IsCompleted)
                                {
                                    <span class="badge bg-success">✅ Concluída</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">⏳ Pendente</span>
                                }
                            </li>

                        }
                    </ul>
                </div>
            }

            <!-- Botões -->
            <div class="d-flex gap-2 mt-4">
                <a href="/dashboard" class="btn btn-outline-secondary">← Voltar ao Dashboard</a>
                <a href="/edit-task/@task.Id" class="btn btn-primary">✏️ Editar</a>
            </div>

        </div>
    }

@code {
    [Parameter] public int Id { get; set; }
    private TaskItem? task;
    private List<TaskItem> dependencies = new();
    private bool hasPendingDeps;

    protected override async Task OnInitializedAsync()
    {
        task = await TaskService.GetTaskByIdAsync(Id);
        dependencies = await TaskService.GetDependenciesAsync(Id);
        hasPendingDeps = await TaskService.HasPendingDependenciesAsync(Id);
    }

    private async Task ToggleMainTask()
    {
        await TaskService.ToggleCompleteAsync(task!.Id);
        task = await TaskService.GetTaskByIdAsync(Id);
        hasPendingDeps = await TaskService.HasPendingDependenciesAsync(Id);
    }

    private async Task ToggleDependencyTask(int depId)
    {
        await TaskService.ToggleCompleteAsync(depId);
        dependencies = await TaskService.GetDependenciesAsync(Id);
        hasPendingDeps = await TaskService.HasPendingDependenciesAsync(Id);
        task = await TaskService.GetTaskByIdAsync(Id);
    }

    private string GetPriorityClass(int priority) => priority switch
    {
        <= 2  => "bg-danger",
        <= 5  => "bg-warning text-dark",
        <= 10 => "bg-info text-dark",
        <= 20 => "bg-success",
        _     => "bg-secondary"
    };

    private string GetPriorityEmoji(int priority) => priority switch
    {
        <= 2  => "🔴",
        <= 5  => "🟠",
        <= 10 => "🟡",
        <= 20 => "🟢",
        _     => "⚪"
    };
}
