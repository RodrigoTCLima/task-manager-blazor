@page "/"
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<AuthorizeView>
    <Authorized>
        <p>Redirecionando...</p>
    </Authorized>
    <NotAuthorized>
        <div class="d-flex justify-content-center align-items-center" style="min-height: calc(100vh - 3.5rem);">
            <div class="text-center">
                <div class="d-flex align-items-center justify-content-center gap-3 mb-3">
                    <i class="bi bi-check2-square text-success" style="font-size: 3rem;"></i>
                    <h1 class="fw-bold mb-0">TaskManager</h1>
                </div>
                <p class="text-muted mb-4">Organize suas tarefas com eficiência</p>
                <div class="d-flex justify-content-center gap-2">
                    <a href="/Identity/Account/Register" class="btn btn-primary">Criar Conta</a>
                    <a href="/Identity/Account/Login" class="btn btn-outline-primary">Entrar</a>
                </div>
            </div>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            if (authState.User.Identity?.IsAuthenticated == true)
                Navigation.NavigateTo("/tasks");
        }
    }
}