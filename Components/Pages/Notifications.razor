@page "/notifications"
@using TaskManager.Services
@using TaskManager.Models
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject NotificationService NotificationService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav
@rendermode InteractiveServer

<PageTitle>Notificações</PageTitle>

<div class="container py-4" style="max-width:680px;">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <h4 class="mb-0"><i class="bi bi-bell me-2"></i>Notificações</h4>
        @if (notifications.Any(n => !n.IsRead))
        {
            <button class="btn btn-sm btn-outline-secondary" @onclick="MarkAllRead">
                Marcar todas como lidas
            </button>
        }
    </div>

    @if (notifications.Count == 0)
    {
        <div class="text-center text-muted py-5">
            <i class="bi bi-bell-slash fs-1 d-block mb-3"></i>
            Nenhuma notificação por enquanto.
        </div>
    }
    else
    {
        <div class="list-group">
            @foreach (var n in notifications)
            {
                <div class="list-group-item list-group-item-action d-flex align-items-start gap-3 @(n.IsRead ? "" : "fw-semibold bg-light")"
                     style="cursor:pointer;" @onclick="() => HandleClick(n)">
                    <div class="pt-1">
                        <i class="bi @GetIcon(n.Type) @GetIconColor(n.Type)"></i>
                    </div>
                    <div class="flex-fill">
    <div>@n.Message</div>
    <div class="d-flex align-items-center gap-2 mt-1">
        <small class="text-muted">@FormatDate(n.CreatedAt)</small>
        @if (n.Link?.StartsWith("/task/") == true || n.Link == "/task" || n.Link == "/organizations")
        {
            <span class="badge bg-secondary" style="font-size:0.65rem;">
                @GetCategory(n.Type)
            </span>
        }
    </div>
</div>

                    <div class="d-flex align-items-center gap-2">
    @if (!n.IsRead)
    {
        <span class="badge bg-primary rounded-pill">Nova</span>
    }
    <button class="btn btn-link p-0 text-danger" title="Excluir"
            @onclick:stopPropagation
            @onclick="() => DeleteNotification(n)">
        <i class="bi bi-trash"></i>
    </button>
</div>
                </div>
            }
        </div>
    }
    <div class="d-flex gap-2">
    @if (notifications.Any(n => !n.IsRead))
    {
        <button class="btn btn-sm btn-outline-secondary" @onclick="MarkAllRead">
            Marcar todas como lidas
        </button>
    }
    @if (notifications.Any())
    {
        <button class="btn btn-sm btn-outline-danger" @onclick="DeleteAll">
            Limpar tudo
        </button>
    }
</div>

</div>

@code {
    private List<Notification> notifications = new();
    private string? userId;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        userId = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        if (!string.IsNullOrEmpty(userId))
            notifications = await NotificationService.GetAllAsync(userId);
    }

    private async Task HandleClick(Notification n)
    {
        if (!n.IsRead)
        {
            await NotificationService.MarkAsReadAsync(n.Id);
            n.IsRead = true;
        }

        if (!string.IsNullOrEmpty(n.Link))
            Nav.NavigateTo(n.Link);
    }

    private async Task MarkAllRead()
    {
        if (string.IsNullOrEmpty(userId)) return;
        await NotificationService.MarkAllAsReadAsync(userId);
        notifications.ForEach(n => n.IsRead = true);
    }

    private string GetIcon(NotificationType type) => type switch
    {
        NotificationType.OrgInviteReceived      => "bi-envelope",
        NotificationType.OrgApplicationReceived => "bi-person-plus",
        NotificationType.OrgInviteAccepted      => "bi-check-circle",
        NotificationType.OrgInviteDeclined      => "bi-x-circle",
        NotificationType.OrgApplicationAccepted => "bi-check-circle",
        NotificationType.OrgApplicationDeclined => "bi-x-circle",
        NotificationType.TaskAssigned           => "bi-person-check",
        NotificationType.TaskReviewPending      => "bi-hourglass-split",
        NotificationType.OrgMemberRemoved => "bi-person-dash",
        NotificationType.TaskCompleted    => "bi-check2-circle",
        NotificationType.TaskReviewed  => "bi-patch-check",
        NotificationType.TaskCommented => "bi-chat-left-text",
        _                                       => "bi-bell"
    };

    private string GetIconColor(NotificationType type) => type switch
    {
        NotificationType.OrgInviteAccepted      => "text-success",
        NotificationType.OrgApplicationAccepted => "text-success",
        NotificationType.OrgInviteDeclined      => "text-danger",
        NotificationType.OrgApplicationDeclined => "text-danger",
        NotificationType.OrgApplicationReceived => "text-primary",
        NotificationType.OrgInviteReceived      => "text-primary",
        NotificationType.OrgMemberRemoved => "text-danger",
        NotificationType.TaskCompleted    => "text-success",
        NotificationType.TaskReviewed  => "text-success",
        NotificationType.TaskCommented => "text-primary",
        _                                       => "text-secondary"
    };

    private string FormatDate(DateTime date)
    {
        var diff = DateTime.UtcNow - date;
        if (diff.TotalMinutes < 1)   return "agora mesmo";
        if (diff.TotalHours < 1)     return $"há {(int)diff.TotalMinutes} min";
        if (diff.TotalDays < 1)      return $"há {(int)diff.TotalHours}h";
        if (diff.TotalDays < 7)      return $"há {(int)diff.TotalDays} dias";
        return date.ToLocalTime().ToString("dd/MM/yyyy");
    }

    private async Task DeleteNotification(Notification n)
{
    await NotificationService.DeleteAsync(n.Id);
    notifications.Remove(n);
}

private async Task DeleteAll()
{
    if (string.IsNullOrEmpty(userId)) return;
    await NotificationService.DeleteAllAsync(userId);
    notifications.Clear();
}

private string GetCategory(NotificationType type) => type switch
{
    NotificationType.TaskAssigned    or
    NotificationType.TaskCompleted   or
    NotificationType.TaskReviewed    or
    NotificationType.TaskCommented   or
    NotificationType.TaskReviewPending => "Tarefa",
    _ => "Organização"
};

}
