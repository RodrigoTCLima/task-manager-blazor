@page "/kanban"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using TaskManager.Models
@using TaskManager.Services
@inject TaskService TaskService
@inject OrganizationService OrgService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav
@rendermode InteractiveServer

<PageTitle>Kanban</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div class="d-flex align-items-center gap-2">
        <i class="bi bi-kanban text-primary"></i>
        <h5 class="mb-0">Kanban</h5>
    </div>
    <div class="d-flex gap-2">
        <a href="/tasks@(orgId.HasValue ? $"?orgId={orgId}" : "")" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-list-task me-1"></i>Lista
        </a>
        <a href="/add-task@(orgId.HasValue ? $"?orgId={orgId}" : "")" class="btn btn-sm btn-success">
            <i class="bi bi-plus"></i> Nova Tarefa
        </a>
    </div>
</div>

@if (accessDenied)
{
    <div class="alert alert-warning">
        <i class="bi bi-lock me-2"></i>Você não tem permissão para ver o Kanban desta organização.
    </div>
}
else if (isLoading)
{
    <div class="d-flex justify-content-center py-5">
        <div class="spinner-border text-primary"></div>
    </div>
}
else
{
    @if (orgId.HasValue && orgName != null)
    {
        <div class="alert alert-primary d-flex justify-content-between align-items-center py-2 mb-3">
            <span>🏢 <strong>@orgName</strong></span>
            @if (canViewOthers)
            {
                <span class="badge bg-primary">Visão geral</span>
            }
            else
            {
                <span class="badge bg-secondary">Suas tarefas</span>
            }
        </div>
    }

    <!-- Filtros -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body py-2 px-3">
            <div class="d-flex flex-wrap align-items-center gap-3">
                <small class="text-muted fw-semibold">Filtros:</small>
                <select class="form-select form-select-sm" style="width:140px;"
                        @bind="filterCategory" @bind:after="ApplyFilters">
                    <option value="">Todas categorias</option>
                    @foreach (var cat in availableCategories)
                    {
                        <option value="@cat">@cat</option>
                    }
                </select>
                <select class="form-select form-select-sm" style="width:150px;"
                        @bind="filterPriority" @bind:after="ApplyFilters">
                    <option value="0">Todas prioridades</option>
                    <option value="2">🔴 Crítica (P≤2)</option>
                    <option value="5">🟠 Alta (P≤5)</option>
                    <option value="10">🟡 Média (P≤10)</option>
                    <option value="20">🟢 Baixa (P≤20)</option>
                </select>
                @if (filterCategory != "" || filterPriority != 0)
                {
                    <button class="btn btn-sm btn-outline-secondary" @onclick="ClearFilters">✕ Limpar</button>
                }
                <small class="text-muted ms-auto">@filteredTasks.Count tarefa(s)</small>
            </div>
        </div>
    </div>

    <!-- Colunas Kanban -->
    <div class="kanban-board">
        @foreach (var col in columns)
        {
            var colTasks = GetColumnTasks(col.Status);
            <div class="kanban-col"
                 @ondragover:preventDefault="true"
                 @ondrop="() => OnDrop(col.Status)">

                <div class="kanban-col-header" style="border-top: 3px solid @col.Color;">
                    <span class="fw-bold">@col.Icon @col.Title</span>
                    <span class="badge rounded-pill" style="background:@col.Color;">@colTasks.Count</span>
                </div>

                <div class="kanban-cards">
                    @foreach (var task in colTasks)
                    {
                        var isDragging = draggingTaskId == task.Id;
                        <div class="kanban-card @(isDragging ? "dragging" : "")"
                             draggable="true"
                             @ondragstart="() => OnDragStart(task.Id)"
                             @ondragend="OnDragEnd">

                            <div class="d-flex align-items-start justify-content-between gap-2 mb-2">
                                <a href="/task/@task.Id"
                                   class="text-decoration-none text-dark fw-semibold small flex-grow-1"
                                   @onclick:stopPropagation="true">
                                    <span class="text-muted me-1" style="font-size:.65rem;">#@task.Id</span>
                                    @task.Title
                                </a>
                                <span class="badge @GetPriorityBadge(task.Priority) flex-shrink-0" style="font-size:.6rem;">
                                    @GetPriorityEmoji(task.Priority) @task.Priority
                                </span>
                            </div>

                            @if (!string.IsNullOrEmpty(task.Description))
                            {
                                <p class="text-muted mb-2" style="font-size:.7rem; line-height:1.3;">
                                    @task.Description[..Math.Min(60, task.Description.Length)]@(task.Description.Length > 60 ? "..." : "")
                                </p>
                            }

                            <div class="d-flex flex-wrap gap-1 align-items-center">
                                <span class="badge bg-light text-dark border" style="font-size:.6rem;">@task.Category</span>
                                @if (task.DueDate.HasValue)
                                {
                                    var overdue = task.DueDate.Value < DateTime.Now && !task.IsCompleted;
                                    <span class="badge @(overdue ? "bg-danger" : "bg-light text-dark border")" style="font-size:.6rem;">
                                        📅 @task.DueDate.Value.ToLocalTime().ToString("dd/MM")
                                    </span>
                                }
                                @foreach (var tag in task.Tags.Take(2))
                                {
                                    <span class="badge bg-info text-dark" style="font-size:.55rem;">@tag</span>
                                }
                                @if (task.AssignedToUserIds.Any())
                                {
                                    <span class="ms-auto badge bg-light text-dark border" style="font-size:.6rem;">
                                        👤 @task.AssignedToUserIds.Count
                                    </span>
                                }
                            </div>

                            @if (task.DependencyOnTaskIds?.Any() == true)
                            {
                                var pendingDeps = task.DependencyOnTaskIds
                                    .Count(depId => allTasks.Any(t => t.Id == depId && !t.IsCompleted));
                                @if (pendingDeps > 0)
                                {
                                    <div class="mt-2">
                                        <span class="badge bg-warning text-dark" style="font-size:.6rem;">
                                            🔒 @pendingDeps dep. pendente(s)
                                        </span>
                                    </div>
                                }
                            }

                            @if (task.IsRecurrent && !string.IsNullOrEmpty(task.RecurrencePattern))
                            {
                                <div class="mt-2">
                                    <span class="badge" style="background:#6f42c1;font-size:.6rem;">
                                        🔄 @GetRecurrenceLabel(task.RecurrencePattern)
                                    </span>
                                </div>
                            }
                        </div>
                    }

                    @if (!colTasks.Any())
                    {
                        <div class="kanban-empty">
                            <span class="text-muted small">Nenhuma tarefa</span>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
}

<!-- Overlay de recorrência -->
@if (showRecurrencePanel)
{
    var pendingTask = allTasks.FirstOrDefault(t => t.Id == pendingRecurrentTaskId);
    <div class="recurrence-backdrop" @onclick="CancelRecurrence"></div>
    <div class="recurrence-overlay">
        <div class="d-flex align-items-center gap-2 mb-3">
            <span class="fs-4">🔄</span>
            <div>
                <h6 class="mb-0 fw-bold">Definir recorrência</h6>
                @if (pendingTask != null)
                {
                    <small class="text-muted">@pendingTask.Title</small>
                }
            </div>
        </div>

        <p class="small fw-semibold mb-2">Com qual frequência esta tarefa se repete?</p>
        <div class="d-flex gap-2 flex-wrap mb-4">
            @foreach (var opt in new[] { ("Daily", "📅 Diária"), ("Weekly", "📆 Semanal"), ("Monthly", "🗓️ Mensal") })
            {
                var isSelected = pendingRecurrencePattern == opt.Item1;
                <button class="btn @(isSelected ? "btn-primary" : "btn-outline-secondary") flex-grow-1"
                        @onclick="() => pendingRecurrencePattern = opt.Item1"
                        @onclick:stopPropagation="true">
                    @opt.Item2
                </button>
            }
        </div>

        <div class="d-flex gap-2">
            <button class="btn btn-primary flex-grow-1" @onclick="ConfirmRecurrence" @onclick:stopPropagation="true">
                <i class="bi bi-check-lg me-1"></i>Confirmar
            </button>
            <button class="btn btn-outline-secondary" @onclick="CancelRecurrence" @onclick:stopPropagation="true">
                Cancelar
            </button>
        </div>
    </div>
}

<style>
    .kanban-board {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px;
        align-items: start;
    }
    .kanban-col {
        background: #f8f9fa;
        border-radius: 10px;
        overflow: hidden;
        min-height: 500px;
        display: flex;
        flex-direction: column;
    }
    .kanban-col-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 12px 14px;
        background: white;
        border-bottom: 1px solid #dee2e6;
        font-size: .9rem;
    }
    .kanban-cards {
        padding: 10px;
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 8px;
        min-height: 100px;
    }
    .kanban-card {
        background: white;
        border: 1px solid #dee2e6;
        border-radius: 8px;
        padding: 10px 12px;
        cursor: grab;
        transition: box-shadow 0.15s, opacity 0.15s, transform 0.15s;
        user-select: none;
    }
    .kanban-card:hover {
        box-shadow: 0 4px 12px rgba(0,0,0,.1);
        transform: translateY(-1px);
    }
    .kanban-card.dragging { opacity: 0.4; cursor: grabbing; }
    .kanban-empty {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 32px 0;
        border: 2px dashed #dee2e6;
        border-radius: 8px;
    }
    .recurrence-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.45);
        z-index: 1040;
    }
    .recurrence-overlay {
        position: fixed;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        z-index: 1050;
        background: white;
        border-radius: 12px;
        padding: 28px 32px;
        width: 380px;
        max-width: calc(100vw - 32px);
        box-shadow: 0 8px 32px rgba(0,0,0,.2);
        border-top: 4px solid #6f42c1;
        animation: overlayIn 0.18s ease;
    }
    @@keyframes overlayIn {
        from { opacity: 0; transform: translate(-50%, -54%); }
        to   { opacity: 1; transform: translate(-50%, -50%); }
    }
    @@media (max-width: 992px) { .kanban-board { grid-template-columns: repeat(2, 1fr); } }
    @@media (max-width: 576px) { .kanban-board { grid-template-columns: 1fr; } }
</style>

@code {
    private bool isLoading = true;
    private bool accessDenied = false;
    private string? currentUserId;
    private int? orgId;
    private string? orgName;
    private bool canViewOthers = false;

    private List<TaskItem> allTasks = new();
    private List<TaskItem> filteredTasks = new();
    private List<string> availableCategories = new();

    private string filterCategory = "";
    private int filterPriority = 0;
    private int? draggingTaskId;

    // Recurrence overlay
    private bool showRecurrencePanel = false;
    private int? pendingRecurrentTaskId;
    private string pendingRecurrencePattern = "Weekly";

    private record KanbanColumn(KanbanStatus Status, string Title, string Icon, string Color);

    private readonly List<KanbanColumn> columns = new()
    {
        new(KanbanStatus.Todo,       "A fazer",      "📋", "#0d6efd"),
        new(KanbanStatus.InProgress, "Em andamento", "⚡", "#fd7e14"),
        new(KanbanStatus.Done,       "Concluída",    "✅", "#198754"),
        new(KanbanStatus.Recurrent,  "Recorrentes",  "🔄", "#6f42c1"),
    };

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        currentUserId = auth.User.FindFirst(
            System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var qs  = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        if (qs.TryGetValue("orgId", out var orgIdStr) && int.TryParse(orgIdStr, out var parsedOrgId))
        {
            orgId   = parsedOrgId;
            var org = await OrgService.GetOrganizationByIdAsync(parsedOrgId);
            orgName = org?.Name;

            if (org != null)
            {
                var role = await OrgService.GetUserRoleAsync(parsedOrgId, currentUserId!);
                if (!role.HasValue || !OrgService.CanViewKanban(org, role.Value))
                {
                    accessDenied = true;
                    isLoading    = false;
                    return;
                }
                canViewOthers = OrgService.CanViewOthersKanban(org, role.Value);
            }
        }

        allTasks = await TaskService.GetAllTasksAsync(currentUserId, orgId);

        if (orgId.HasValue && !canViewOthers)
        {
            allTasks = allTasks
                .Where(t => t.AuthorUserId == currentUserId
                         || t.AssignedToUserIds.Contains(currentUserId!))
                .ToList();
        }

        // Sync: completed -> Done, recurrent -> Recurrent
        foreach (var t in allTasks)
        {
            if (t.IsCompleted)
                t.KanbanStatus = KanbanStatus.Done;
            else if (t.IsRecurrent)
                t.KanbanStatus = KanbanStatus.Recurrent;
        }

        availableCategories = allTasks
            .Select(t => t.Category).Where(c => !string.IsNullOrEmpty(c))
            .Distinct().OrderBy(c => c).ToList();

        ApplyFilters();
        isLoading = false;
    }

    private void ApplyFilters()
    {
        var result = allTasks.AsEnumerable();
        if (!string.IsNullOrEmpty(filterCategory))
            result = result.Where(t => t.Category == filterCategory);
        if (filterPriority > 0)
            result = result.Where(t => t.Priority <= filterPriority);
        filteredTasks = result.ToList();
    }

    private void ClearFilters()
    {
        filterCategory = "";
        filterPriority = 0;
        ApplyFilters();
    }

    private List<TaskItem> GetColumnTasks(KanbanStatus status)
        => filteredTasks.Where(t => t.KanbanStatus == status).OrderBy(t => t.Priority).ToList();

    private void OnDragStart(int taskId) => draggingTaskId = taskId;
    private void OnDragEnd()             => draggingTaskId = null;

    private async Task OnDrop(KanbanStatus targetStatus)
    {
        if (draggingTaskId == null) return;

        var task = allTasks.FirstOrDefault(t => t.Id == draggingTaskId);
        if (task == null || task.KanbanStatus == targetStatus) { draggingTaskId = null; return; }

        // Dropping on Recurrent -> show overlay first
        if (targetStatus == KanbanStatus.Recurrent)
        {
            pendingRecurrentTaskId  = draggingTaskId;
            pendingRecurrencePattern = task.RecurrencePattern ?? "Weekly";
            showRecurrencePanel     = true;
            draggingTaskId          = null;
            StateHasChanged();
            return;
        }

        task.KanbanStatus = targetStatus;
        task.IsCompleted  = targetStatus == KanbanStatus.Done;
        draggingTaskId    = null;
        StateHasChanged();

        await TaskService.UpdateKanbanStatusAsync(task.Id, targetStatus, currentUserId!);
    }

    private async Task ConfirmRecurrence()
    {
        if (pendingRecurrentTaskId == null) return;

        var task = allTasks.FirstOrDefault(t => t.Id == pendingRecurrentTaskId);
        if (task != null)
        {
            task.KanbanStatus      = KanbanStatus.Recurrent;
            task.IsRecurrent       = true;
            task.RecurrencePattern = pendingRecurrencePattern;
        }

        showRecurrencePanel    = false;
        var taskId             = pendingRecurrentTaskId.Value;
        var pattern            = pendingRecurrencePattern;
        pendingRecurrentTaskId = null;
        StateHasChanged();

        await TaskService.UpdateKanbanStatusAsync(taskId, KanbanStatus.Recurrent, currentUserId!, pattern);
    }

    private void CancelRecurrence()
    {
        showRecurrencePanel    = false;
        pendingRecurrentTaskId = null;
    }

    private string GetRecurrenceLabel(string pattern) => pattern switch
    {
        "Daily"   => "Diária",
        "Weekly"  => "Semanal",
        "Monthly" => "Mensal",
        _         => pattern
    };

    private string GetPriorityBadge(int p) => p switch
    {
        <= 2  => "bg-danger",
        <= 5  => "bg-warning text-dark",
        <= 10 => "bg-info text-dark",
        <= 20 => "bg-success",
        _     => "bg-secondary"
    };

    private string GetPriorityEmoji(int p) => p switch
    {
        <= 2  => "🔴",
        <= 5  => "🟠",
        <= 10 => "🟡",
        <= 20 => "🟢",
        _     => "⚪"
    };
}
