@page "/add-task"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@page "/edit-task/{TaskId:int}"
@attribute [Authorize]
@using TaskManager.Models
@using TaskManager.Services
@using System.ComponentModel.DataAnnotations
@inject TaskService TaskService
@inject OrganizationService OrgService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject AppState AppState

@rendermode InteractiveServer

<PageTitle>@(editingTask != null ? "Editar Tarefa" : "Nova Tarefa")</PageTitle>

<div class="d-flex align-items-center justify-content-between mb-4">
    <div class="d-flex align-items-center gap-2">
        <i class="bi @(editingTask != null ? "bi-pencil-square" : "bi-plus-circle") text-primary"></i>
        <h5 class="mb-0">@(editingTask != null ? "Editar Tarefa" : "Nova Tarefa")</h5>
    </div>
    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="Cancel">
        <i class="bi bi-arrow-left me-1"></i>Voltar
    </button>
</div>

@if (!string.IsNullOrEmpty(permissionError))
{
    <div class="alert alert-danger d-flex align-items-center gap-2 mb-4">
        <i class="bi bi-slash-circle"></i>
        <span>@permissionError</span>
        <a href="/organizations" class="btn btn-sm btn-outline-danger ms-auto">Ver Organizações</a>
    </div>
}

<EditForm Model="@taskModel" OnValidSubmit="@HandleValidSubmit" FormName="taskForm">
    <DataAnnotationsValidator />
    <ValidationSummary class="alert alert-danger small" />

    <div class="row g-4 align-items-start">

        <!-- COLUNA ESQUERDA: título, descrição, prazo, dependências -->
        <div class="col-lg-8 d-flex flex-column gap-4">

            <!-- Título + Prioridade -->
            <div class="row g-3">
                <div class="col-md-8">
                    <label class="form-label fw-semibold">Título <span class="text-danger">*</span></label>
                    <InputText @bind-Value="taskModel.Title" class="form-control" placeholder="Nome da tarefa..." />
                    <ValidationMessage For="@(() => taskModel.Title)" class="text-danger small" />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Prioridade</label>
                    <div class="input-group">
                        <InputNumber @bind-Value="taskModel.Priority" class="form-control" min="1" max="100" />
                        <span class="input-group-text">@GetPriorityEmoji(taskModel.Priority)</span>
                    </div>
                    <div class="form-text">
                        Ex: 1=🔴 Crítica, 5=🟡 Normal, 20=🟢 Baixa
                    </div>
                </div>
            </div>

            <!-- Descrição -->
            <div>
                <label class="form-label fw-semibold">Descrição</label>
                <InputTextArea @bind-Value="taskModel.Description" class="form-control" rows="3"
                               placeholder="Detalhes opcionais..." />
            </div>

            <!-- Prazo + Alarme + Recorrência -->
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Prazo</label>
                    <InputDate @bind-Value="taskModel.DueDate" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Alarme</label>
                    <div class="form-check mt-2">
                        <InputCheckbox @bind-Value="taskModel.HasAlarm" class="form-check-input" id="chkAlarm" />
                        <label class="form-check-label" for="chkAlarm">Ativar alarme</label>
                    </div>
                    @if (taskModel.HasAlarm)
                    {
                        <InputDate @bind-Value="taskModel.AlarmTime" class="form-control mt-2" />
                    }
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Recorrência</label>
                    <div class="form-check mt-2">
                        <InputCheckbox @bind-Value="taskModel.IsRecurrent" class="form-check-input" id="chkRecurrent" />
                        <label class="form-check-label" for="chkRecurrent">Recorrente</label>
                    </div>
                    @if (taskModel.IsRecurrent)
                    {
                        <InputSelect @bind-Value="taskModel.RecurrencePattern" class="form-select mt-2">
                            <option value="Daily">Diária</option>
                            <option value="Weekly">Semanal</option>
                            <option value="Monthly">Mensal</option>
                        </InputSelect>
                    }
                </div>
            </div>

            <!-- Dependências -->
            <div>
                <div class="d-flex align-items-center gap-2 mb-2">
                    <label class="form-label fw-semibold mb-0">Dependências</label>
                    @if (taskModel.DependencyOnTaskIds?.Any() == true)
                    {
                        <span class="badge bg-primary rounded-pill">@taskModel.DependencyOnTaskIds.Count
                            selecionada(s)</span>
                        }
                    </div>
                    @if (priorityAdjustedMsg != null)
                    {
                        <div class="alert alert-info py-2 px-3 mb-2 small">
                            <i class="bi bi-info-circle me-1"></i>@priorityAdjustedMsg
                        </div>
                    }
                    @if (availableTasks.Any())
                    {
                        <input type="text" class="form-control form-control-sm mb-2"
                               placeholder="🔍 Filtrar por nome ou #número..." @bind="depFilter" @bind:event="oninput" />
                        <div class="border rounded" style="max-height: 200px; overflow-y: auto;">
                            @{
                                var filtered = string.IsNullOrWhiteSpace(depFilter)
                                    ? availableTasks
                                    : availableTasks.Where(t =>
                                        t.Title.Contains(depFilter, StringComparison.OrdinalIgnoreCase) ||
                                        t.Id.ToString().Contains(depFilter)).ToList();
                            }
                            @if (!filtered.Any())
                            {
                                <p class="text-muted small mb-0 p-3">Nenhuma tarefa encontrada.</p>
                            }
                            else
                            {
                                @foreach (var t in filtered)
                                {
                                    @if (!forbiddenIds.Contains(t.Id))
                                    {
                                        <div class="d-flex align-items-center gap-2 px-3 py-2 border-bottom">
                                            <input class="form-check-input flex-shrink-0" type="checkbox" id="dep_@t.Id"
                                                   checked="@(taskModel.DependencyOnTaskIds != null && taskModel.DependencyOnTaskIds.Contains(t.Id))"
                                                   @onchange="() => ToggleDependency(t.Id)" />
                                            <label class="form-check-label flex-grow-1 mb-0 small" for="dep_@t.Id" title="@t.Description">
                                                <span class="text-muted me-1">#@t.Id</span>@t.Title
                                                @if (t.IsCompleted)
                                                {
                                                    <span class="badge bg-success ms-1 small">✅</span>
                                                }
                                            </label>
                                            <span class="badge @GetPriorityBadgeClass(t.Priority)">@GetPriorityEmoji(t.Priority)
                                                @t.Priority</span>
                                                <span class="badge bg-light text-dark border small">@t.Category</span>
                                            </div>
                                        }
                                    }
                                }
                            </div>
                        }
                else
                        {
                            <p class="text-muted small">Nenhuma tarefa pendente disponível para dependência.</p>
                        }
                    </div>

                </div>

                <!-- COLUNA DIREITA: categoria, tags, org, pessoas, botões -->
                <div class="col-lg-4 d-flex flex-column gap-4">

                    <!-- Categoria -->
                    <div>
                        <label class="form-label fw-semibold">Categoria</label>
                        <InputSelect @bind-Value="taskModel.Category" class="form-select">
                            <option>Geral</option>
                            <option>Trabalho</option>
                            <option>Pessoal</option>
                            <option>Estudos</option>
                            <option>Saúde</option>
                        </InputSelect>
                    </div>

                    <!-- Tags -->
                    <div>
                        <label class="form-label fw-semibold">Tags</label>
                        <InputText @bind-Value="@tagsInput" class="form-control" placeholder="ex: urgente, reunião" />
                        <div class="form-text">Separadas por vírgula</div>
                    </div>

                    <!-- Organização -->
                    <div>
                        <label class="form-label fw-semibold">Organização</label>
                        <select class="form-select" value="@selectedOrgId" @onchange="OnOrgChanged">
                            <option value="">— Nenhuma (pessoal) —</option>
                            @foreach (var org in allowedOrgs)
                            {
                                <option value="@org.Id">@org.Name</option>
                            }
                        </select>
                    </div>

                    <!-- Assignees + Revisores (aparecem após selecionar org) -->
                    @if (selectedOrgId != null && orgMembers.Any())
                    {
                        <div>
                            <label class="form-label fw-semibold">Atribuir a</label>
                            <div class="border rounded" style="max-height: 150px; overflow-y: auto;">
                                @foreach (var member in orgMembers)
                                {
                                    <div class="d-flex align-items-center gap-2 px-3 py-2 border-bottom">
                                        <input class="form-check-input flex-shrink-0" type="checkbox" id="assignee_@member.UserId"
                                               checked="@(taskModel.AssignedToUserIds != null && taskModel.AssignedToUserIds.Contains(member.UserId))"
                                               @onchange="() => ToggleAssignee(member.UserId)" />
                                        <label class="form-check-label flex-grow-1 mb-0 small" for="assignee_@member.UserId">
                                            @member.UserName
                                        </label>
                                        <span class="badge @RoleBadge(member.Role) small">@member.Role</span>
                                    </div>
                                }
                            </div>
                        </div>

                        <div>
                            <label class="form-label fw-semibold">Revisores</label>
                            <div class="border rounded" style="max-height: 150px; overflow-y: auto;">
                                @foreach (var member in orgMembers)
                                {
                                    <div class="d-flex align-items-center gap-2 px-3 py-2 border-bottom">
                                        <input class="form-check-input flex-shrink-0" type="checkbox" id="reviewer_@member.UserId"
                                               checked="@(taskModel.ReviewByUserId != null && taskModel.ReviewByUserId.Contains(member.UserId))"
                                               @onchange="() => ToggleReviewer(member.UserId)" />
                                        <label class="form-check-label flex-grow-1 mb-0 small" for="reviewer_@member.UserId">
                                            @member.UserName
                                        </label>
                                    </div>
                                }
                            </div>
                            @if (taskModel.ReviewByUserId?.Any() == true)
                            {
                                <div class="mt-2 d-flex align-items-center gap-2">
                                    <label class="form-label mb-0 small fw-semibold">Revisões necessárias:</label>
                                    <InputNumber @bind-Value="taskModel.NeedsReview" class="form-control form-control-sm"
                                                 style="max-width: 70px;" min="0" max="20" />
                                </div>
                            }
                        </div>
                    }

                    <!-- Botões -->
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi @(editingTask != null ? "bi-check-lg" : "bi-plus-lg") me-1"></i>
                            @(editingTask != null ? "Salvar Alterações" : "Criar Tarefa")
                        </button>
                        <button type="button" class="btn btn-outline-secondary" @onclick="Cancel">
                            Cancelar
                        </button>
                    </div>

                </div>
            </div>

            <!-- COMENTÁRIOS: abaixo de tudo, só em edição -->
            @if (TaskId.HasValue)
            {
                <hr class="mt-4" />
                <div class="mt-3">
                    <label class="form-label fw-semibold">
                        <i class="bi bi-chat-left-text me-2 text-primary"></i>Comentários
                    </label>
                    <TaskComments TaskId="@(TaskId ?? 0)" />
                </div>
            }

        </EditForm>
        <!-- Confirmation overlay -->
        @if (showConfirm)
        {
            var depTasks = availableTasks
                .Where(t => taskModel.DependencyOnTaskIds != null && taskModel.DependencyOnTaskIds.Contains(t.Id))
                .ToList();
            var orgLabel = allowedOrgs.FirstOrDefault(o => o.Id == taskModel.OrganizationId)?.Name ?? "Pessoal";

            <div class="confirm-backdrop" @onclick="() => showConfirm = false"></div>
            <div class="confirm-overlay">
                <div class="d-flex align-items-center gap-2 mb-3">
                    <i class="bi bi-check2-circle text-primary fs-4"></i>
                    <h6 class="mb-0 fw-bold">Confirmar tarefa</h6>
                </div>

                <div class="confirm-field">
                    <span class="confirm-label">Título</span>
                    <span class="fw-semibold">@taskModel.Title</span>
                </div>
                <div class="confirm-field">
                    <span class="confirm-label">Prioridade</span>
                    <span class="badge @GetPriorityBadgeClass(taskModel.Priority)">
                        @GetPriorityEmoji(taskModel.Priority) @taskModel.Priority
                    </span>
                </div>
                <div class="confirm-field">
                    <span class="confirm-label">Vencimento</span>
                    <span>@(taskModel.DueDate.HasValue ? taskModel.DueDate.Value.ToString("dd/MM/yyyy") : "Hoje")</span>
                </div>
                <div class="confirm-field">
                    <span class="confirm-label">Organização</span>
                    <span>@orgLabel</span>
                </div>
                @if (taskModel.IsRecurrent)
                {
                    <div class="confirm-field">
                        <span class="confirm-label">Recorrência</span>
                        <span class="badge" style="background:#6f42c1;">
                            🔄 @(taskModel.RecurrencePattern switch
                            {
                                "Daily" => "Diária",
                                "Weekly" => "Semanal",
                                "Monthly" => "Mensal",
                                _ => taskModel.RecurrencePattern
                            })
                        </span>
                    </div>
                }
                @if (depTasks.Any())
                {
                    <div class="confirm-field align-items-start">
                        <span class="confirm-label">Dependências</span>
                        <div class="d-flex flex-column gap-1">
                            @foreach (var dep in depTasks)
                            {
                                <span class="badge bg-light text-dark border">
                                    <span class="text-muted me-1">#@dep.Id</span>@dep.Title
                                </span>
                            }
                        </div>
                    </div>
                }

                <div class="d-flex gap-2 mt-4">
                    <button class="btn btn-primary flex-grow-1" @onclick="SaveConfirmed" @onclick:stopPropagation="true">
                        <i class="bi bi-check-lg me-1"></i>
                        @(TaskId.HasValue ? "Salvar Alterações" : "Criar Tarefa")
                    </button>
                    <button class="btn btn-outline-secondary" @onclick="() => showConfirm = false" @onclick:stopPropagation="true">
                        Revisar
                    </button>
                </div>
            </div>
        }

        <style>
            .confirm-backdrop {
                position: fixed;
                inset: 0;
                background: rgba(0, 0, 0, 0.4);
                z-index: 1040;
            }

            .confirm-overlay {
                position: fixed;
                top: 50%;
                left: 50%;
                transform: translate(-50%, -50%);
                z-index: 1050;
                background: var(--bg-card, white);
                color: var(--text-body, #212529);
                border-radius: 12px;
                padding: 28px 32px;
                width: 400px;
                max-width: calc(100vw - 32px);
                box-shadow: 0 8px 32px rgba(0, 0, 0, .18);
                border-top: 4px solid #0d6efd;
                animation: confirmIn 0.18s ease;
            }

            @@keyframes confirmIn {
                from {
                    opacity: 0;
                    transform: translate(-50%, -54%);
                }

                to {
                    opacity: 1;
                    transform: translate(-50%, -50%);
                }
            }

            .confirm-field {
                display: flex;
                align-items: center;
                gap: 12px;
                padding: 8px 0;
                border-bottom: 1px solid var(--border-color, #f0f0f0);
                font-size: .9rem;
            }

            .confirm-label {
                min-width: 100px;
                color: var(--text-muted, #6c757d);
                font-size: .8rem;
                font-weight: 600;
                text-transform: uppercase;
                letter-spacing: .04em;
            }
        </style>

@code {
    [Parameter] public int? TaskId { get; set; }
    private TaskItem? editingTask;
    private TaskItem taskModel = new() { RecurrencePattern = "Daily" };
    private bool showConfirm = false;
    private string tagsInput = "";
    private string? currentUserId;
    private List<TaskItem> availableTasks = new();
    private string depFilter = "";
    private string? priorityAdjustedMsg;
    private HashSet<int> forbiddenIds = new();

    // Org
    private List<Organization> allowedOrgs = new();
    private List<OrganizationMember> orgMembers = new();
    private int? selectedOrgId;
    private string? permissionError;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        currentUserId = authState.User.FindFirst(
            System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        var allOrgs = await OrgService.GetUserOrganizationsAsync(currentUserId!);
        foreach (var org in allOrgs)
        {
            var role = await OrgService.GetUserRoleAsync(org.Id, currentUserId!);
            if (role.HasValue && OrgService.CanCreateTask(org, role.Value))
                allowedOrgs.Add(org);
        }

        // Ler ?orgId= da URL ANTES de buscar tasks
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var qs = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        if (qs.TryGetValue("orgId", out var orgIdStr) && int.TryParse(orgIdStr, out var parsedOrgId))
        {
            if (allowedOrgs.Any(o => o.Id == parsedOrgId))
            {
                selectedOrgId = parsedOrgId;
                taskModel.OrganizationId = parsedOrgId;
                await LoadOrgMembers(parsedOrgId);
            }
        }

        if (TaskId.HasValue)
        {
            editingTask = await TaskService.GetTaskByIdAsync(TaskId.Value);

            if (editingTask != null)
            {
                if (editingTask.OrganizationId.HasValue)
                {
                    var orgForEdit = allOrgs.FirstOrDefault(o => o.Id == editingTask.OrganizationId);
                    var roleForEdit = await OrgService.GetUserRoleAsync(editingTask.OrganizationId.Value, currentUserId!);
                    if (orgForEdit == null || !roleForEdit.HasValue || !OrgService.CanCreateTask(orgForEdit, roleForEdit.Value))
                    {
                        permissionError = "Você não tem permissão para editar tasks desta organização.";
                        return;
                    }
                    selectedOrgId = editingTask.OrganizationId;
                    taskModel.OrganizationId = editingTask.OrganizationId;
                    await LoadOrgMembers(editingTask.OrganizationId.Value);
                }

                // Busca tasks já com orgId correto
                var allMine = await TaskService.GetAllTasksAsync(currentUserId, taskModel.OrganizationId);

                taskModel = new TaskItem
                {
                    Id = editingTask.Id,
                    Title = editingTask.Title,
                    Description = editingTask.Description,
                    Priority = editingTask.Priority,
                    Category = editingTask.Category,
                    DueDate = editingTask.DueDate,
                    HasAlarm = editingTask.HasAlarm,
                    AlarmTime = editingTask.AlarmTime,
                    IsRecurrent = editingTask.IsRecurrent,
                    RecurrencePattern = editingTask.RecurrencePattern,
                    IsCompleted = editingTask.IsCompleted,
                    Tags = new List<string>(editingTask.Tags ?? new()),
                    DependencyOnTaskIds = new List<int>(editingTask.DependencyOnTaskIds ?? new()),
                    AssignedToUserIds = new List<string>(editingTask.AssignedToUserIds ?? new()),
                    ReviewByUserId = new List<string>(editingTask.ReviewByUserId ?? new()),
                    NeedsReview = editingTask.NeedsReview,
                    AuthorUserId = editingTask.AuthorUserId,
                    OrganizationId = editingTask.OrganizationId,
                    CreatedAt = editingTask.CreatedAt
                };
                tagsInput = string.Join(",", taskModel.Tags);

                var selectedIds = taskModel.DependencyOnTaskIds;
                availableTasks = allMine
                    .Where(t => t.Id != TaskId.Value && (!t.IsCompleted || selectedIds.Contains(t.Id)))
                    .ToList();
            }
            else
            {
                Navigation.NavigateTo("/tasks");
            }
        }
        else
        {
            // Nova task — busca com orgId já definido
            var allMine = await TaskService.GetAllTasksAsync(currentUserId, taskModel.OrganizationId);
            availableTasks = allMine.Where(t => !t.IsCompleted).ToList();
            taskModel.CreatedAt = DateTime.UtcNow;
            taskModel.AuthorUserId = currentUserId!;
            taskModel.AssignedToUserIds = new List<string>();
            taskModel.ReviewByUserId = new List<string>();
        }

        if (taskModel.Id > 0)
        {
            forbiddenIds = await TaskService.GetDependencyChainAsync(taskModel.Id);
            forbiddenIds.Add(taskModel.Id);
        }
        else
        {
            forbiddenIds = new HashSet<int>();
        }

        // Pré-preenche data de prazo se vier do calendário (?dueDate=yyyy-MM-dd)
        // Reutiliza qs já declarado acima neste método
        if (editingTask == null && qs.TryGetValue("dueDate", out var dueDateStr) &&
            DateTime.TryParse(dueDateStr, out var parsedDueDate))
        {
            taskModel.DueDate = parsedDueDate;
        }
    }


    private async Task OnOrgChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var orgId))
        {
            selectedOrgId = orgId;
            taskModel.OrganizationId = orgId;
            await LoadOrgMembers(orgId);
            // Busca tasks APENAS da org selecionada
            var tasks = await TaskService.GetAllTasksAsync(currentUserId, orgId);
            availableTasks = tasks.Where(t => !t.IsCompleted && t.Id != (TaskId ?? 0)).ToList();
        }
        else
        {
            selectedOrgId = null;
            taskModel.OrganizationId = null;
            taskModel.AssignedToUserIds = new List<string>();
            taskModel.ReviewByUserId = new List<string>();
            orgMembers = new();
            // Busca tasks pessoais (sem org)
            var tasks = await TaskService.GetAllTasksAsync(currentUserId, null);
            availableTasks = tasks.Where(t => !t.IsCompleted && t.Id != (TaskId ?? 0)).ToList();
        }
    }


    private async Task LoadOrgMembers(int orgId)
    {
        var org = await OrgService.GetOrganizationByIdAsync(orgId);
        orgMembers = org?.Members.ToList() ?? new();
    }

    private void ToggleAssignee(string userId)
    {
        taskModel.AssignedToUserIds ??= new List<string>();
        if (taskModel.AssignedToUserIds.Contains(userId))
            taskModel.AssignedToUserIds.Remove(userId);
        else
            taskModel.AssignedToUserIds.Add(userId);
    }

    private void ToggleReviewer(string userId)
    {
        taskModel.ReviewByUserId ??= new List<string>();
        if (taskModel.ReviewByUserId.Contains(userId))
            taskModel.ReviewByUserId.Remove(userId);
        else
            taskModel.ReviewByUserId.Add(userId);

        if (!taskModel.ReviewByUserId.Any())
            taskModel.NeedsReview = 0;
    }

    private async Task HandleValidSubmit()
    {
        if (!string.IsNullOrEmpty(permissionError)) return;

        taskModel.Tags = tagsInput.Split(',', StringSplitOptions.RemoveEmptyEntries)
            .Select(t => t.Trim()).Where(t => !string.IsNullOrEmpty(t)).ToList();

        // Default DueDate to today if not set
        if (!taskModel.DueDate.HasValue)
            taskModel.DueDate = DateTime.UtcNow.Date;

        // Default RecurrencePattern if recurrent but none selected
        if (taskModel.IsRecurrent && string.IsNullOrEmpty(taskModel.RecurrencePattern))
            taskModel.RecurrencePattern = "Daily";

        showConfirm = true;
    }

    private async Task SaveConfirmed()
    {
        showConfirm = false;

        // Normalize to UTC noon — prevents timezone shift from moving date one day back
        if (taskModel.DueDate.HasValue)
            taskModel.DueDate = DateTime.SpecifyKind(taskModel.DueDate.Value.Date.AddHours(12), DateTimeKind.Utc);
        if (taskModel.AlarmTime.HasValue)
            taskModel.AlarmTime = DateTime.SpecifyKind(taskModel.AlarmTime.Value.Date.AddHours(12), DateTimeKind.Utc);

        if (TaskId.HasValue && editingTask != null)
        {
            taskModel.Id = editingTask.Id;
            await TaskService.UpdateTaskAsync(taskModel, currentUserId);
        }
        else
        {
            await TaskService.CreateTaskAsync(taskModel);
        }

        AppState.NotifyTasksChanged();

        var redirect = taskModel.OrganizationId.HasValue
            ? $"/tasks?orgId={taskModel.OrganizationId}"
            : "/tasks";
        Navigation.NavigateTo(redirect);
    }

    private void ToggleDependency(int id)
    {
        priorityAdjustedMsg = null;
        taskModel.DependencyOnTaskIds ??= new List<int>();

        if (taskModel.DependencyOnTaskIds.Contains(id))
        {
            taskModel.DependencyOnTaskIds.Remove(id);
            return;
        }

        taskModel.DependencyOnTaskIds.Add(id);

        var dep = availableTasks.FirstOrDefault(t => t.Id == id);
        if (dep != null && taskModel.Priority <= dep.Priority)
        {
            var oldPriority = taskModel.Priority;
            taskModel.Priority = dep.Priority + 1;
            priorityAdjustedMsg = $"ℹ️ Prioridade ajustada de {oldPriority} para {taskModel.Priority} (deve ser menos urgente que #{id} com prioridade {dep.Priority}).";
        }
    }

    private void Cancel()
    {
        var redirect = taskModel.OrganizationId.HasValue
            ? $"/tasks?orgId={taskModel.OrganizationId}"
            : "/tasks";
        Navigation.NavigateTo(redirect);
    }

    private string GetPriorityEmoji(int priority) =>
        priority switch { <= 2 => "🔴", <= 5 => "🟠", <= 10 => "🟡", <= 20 => "🟢", _ => "⚪" };

    private string GetPriorityBadgeClass(int priority) =>
        priority switch
        {
            <= 2 => "bg-danger",
            <= 5 => "bg-warning text-dark",
            <= 10 => "bg-info text-dark",
            <= 20 => "bg-success",
            _ => "bg-secondary"
        };

    private string RoleBadge(MemberRole role) => role switch
    {
        MemberRole.Owner => "bg-danger",
        MemberRole.Admin => "bg-warning text-dark",
        _ => "bg-secondary"
    };
}