@page "/add-task"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@page "/edit-task/{TaskId:int}"
@attribute [Authorize]
@using TaskManager.Models
@using TaskManager.Services
@using System.ComponentModel.DataAnnotations
@inject TaskService TaskService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

@rendermode InteractiveServer

<PageTitle>@(editingTask != null ? "Editar Tarefa" : "Nova Tarefa")</PageTitle>

<h3>@(editingTask != null ? "Editar Tarefa" : "Nova Tarefa")</h3>

<EditForm Model="@taskModel" OnValidSubmit="@HandleValidSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="row mb-3">
        <div class="col-md-8">
            <label>Título *</label>
            <InputText @bind-Value="taskModel.Title" class="form-control" />
            <ValidationMessage For="@(() => taskModel.Title)" />
        </div>
        <div class="col-md-4">
            <label>Prioridade (número menor = mais urgente)</label>
            <div class="input-group">
                <InputNumber @bind-Value="taskModel.Priority" class="form-control" min="1" max="100" />
                <span class="input-group-text">@GetPriorityEmoji(taskModel.Priority)
                </span>
            </div>
            <div class="form-text">
                Ex: 1=🔴 Crítica, 5=🟡 Normal, 20=🟢 Baixa
            </div>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-6">
            <label>Descrição</label>
            <InputTextArea @bind-Value="taskModel.Description" class="form-control" rows="3" />
        </div>
        <div class="col-md-6">
            <label>Categoria</label>
            <InputSelect @bind-Value="taskModel.Category" class="form-select">
                <option>Geral</option>
                <option>Trabalho</option>
                <option>Pessoal</option>
                <option>Estudos</option>
                <option>Saúde</option>
            </InputSelect>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-3">
            <label>Prazo</label>
            <InputDate @bind-Value="taskModel.DueDate" class="form-control"></InputDate>
        </div>
    </div>

    <div class="col-md-3">
        <label>Alarme</label>
        <label class="form-check-label">
            <InputCheckbox @bind-Value="taskModel.HasAlarm" class="form-check-input" />
            Ativar alarme para esta tarefa
        </label>
        @if (taskModel.HasAlarm)
        {
            <InputDate @bind-Value="taskModel.AlarmTime" class="form-control mt-1" />
        }
    </div>

    <div class="col-md-3">
        <label>Recorrente</label>
        <label class="form-check-label">
            <InputCheckbox @bind-Value="taskModel.IsRecurrent" class="form-check-input" />
            Tarefa recorrente
        </label>
        @if (taskModel.IsRecurrent)
        {
            <InputSelect @bind-Value="taskModel.RecurrencePattern" class="form-select mt-1">
                <option value="Daily">Diária</option>
                <option value="Weekly">Semanal</option>
                <option value="Monthly">Mensal</option>
            </InputSelect>
        }
    </div>
    <div class="col-md-3">
        <label>Tags (separadas por vírgula)</label>
        <InputText @bind-Value="@tagsInput" class="form-control" placeholder="ex: urgente,trabalho" />
    </div>

    <div class="mb-3">
        <label>Dependências</label>
        @if (availableTasks.Any())
        {
            <input type="text"               class="form-control form-control-sm mb-2"               placeholder="🔍 Filtrar por nome ou #número..."
                   @bind="depFilter"               @bind:event="oninput" />

            <div class="border rounded p-2" style="max-height: 200px; overflow-y: auto;">
                @{
                    var filtered = string.IsNullOrWhiteSpace(depFilter)
                        ? availableTasks
                        : availableTasks.Where(t =>
                            t.Title.Contains(depFilter, StringComparison.OrdinalIgnoreCase) ||
                            t.Id.ToString().Contains(depFilter)).ToList();
                }
                @if (!filtered.Any())
                {
                    <p class="text-muted small mb-0">Nenhuma tarefa encontrada.</p>
                }
                else
                {
                    @foreach (var t in filtered)
                    {
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="dep_@t.Id"
                                   checked="@(taskModel.DependencyOnTaskIds?.Contains(t.Id) ?? false)"
                                   @onchange="() => ToggleDependency(t.Id)" />
                            <label class="form-check-label" for="dep_@t.Id">
                                <span class="text-muted me-1">#@t.Id</span>@t.Title
                            </label>
                        </div>
                    }
                }
            </div>
        }
        else
        {
            <p class="text-muted small">Nenhuma tarefa pendente disponível.</p>
        }
    </div>



    <TaskComments TaskId="@(TaskId ?? 0)" />

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">@((editingTask != null) ? "Salvar Alterações" : "Adicionar            Tarefa")</button>
        <button type="button" class="btn btn-secondary" @onclick="Cancel">Cancelar</button>
    </div>
</EditForm>
@code {
    [Parameter] public int? TaskId { get; set; }
    private TaskItem? editingTask;
    private TaskItem taskModel = new();
    private string tagsInput = "";
    private string? currentUserId;
    private List<TaskItem> availableTasks = new();
    private string depFilter = "";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        currentUserId = authState.User.Identity?.Name;

        var all = await TaskService.GetAllTasksAsync(currentUserId);

        if (TaskId.HasValue)
        {
            editingTask = await TaskService.GetTaskByIdAsync(TaskId.Value);
            availableTasks = all
                .Where(t => !t.IsCompleted && t.Id != TaskId.Value)
                .ToList();

            if (editingTask != null)
            {
                taskModel = editingTask;
                tagsInput = string.Join(",", taskModel.Tags);
            }
            else
            {
                Navigation.NavigateTo("/tasks");
            }
        }
        else
        {
            availableTasks = all.Where(t => !t.IsCompleted).ToList();
            taskModel.CreatedAt = DateTime.Now;
            taskModel.AuthorUserId = currentUserId;
        }
    }
    private async Task HandleValidSubmit()
    {
        // Processar tags
        taskModel.Tags = tagsInput.Split(',', StringSplitOptions.RemoveEmptyEntries)
            .Select(t => t.Trim()).Where(t => !string.IsNullOrEmpty(t)).ToList();


        if (TaskId.HasValue && editingTask != null)
        {
            taskModel.Id = editingTask.Id; // Preserva ID
            await TaskService.UpdateTaskAsync(taskModel);
        }
        else
        {
            await TaskService.CreateTaskAsync(taskModel);
        }

        Navigation.NavigateTo("/tasks");
    }

    private void ToggleDependency(int id)
    {
        taskModel.DependencyOnTaskIds ??= new List<int>();
        if (taskModel.DependencyOnTaskIds.Contains(id))
            taskModel.DependencyOnTaskIds.Remove(id);
        else
            taskModel.DependencyOnTaskIds.Add(id);
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/tasks");
    }

    private string GetPriorityEmoji(int priority) =>
        priority switch { <= 2 => "🔴", <= 5 => "🟠", <= 10 => "🟡", <= 20 => "🟢", _ => "⚪" };
}