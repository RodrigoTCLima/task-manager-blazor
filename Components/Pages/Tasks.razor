@page "/tasks"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@using TaskManager.Services
@using TaskManager.Models
@using TaskManager.DTOs
@inject TaskService TaskService
@inject NavigationManager Nav
@inject OrganizationService OrgService
@inject AuthenticationStateProvider AuthStateProvider
@implements IDisposable
@rendermode InteractiveServer

<PageTitle>Tarefas</PageTitle>

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <h1 class="mb-0 fs-4">Gerenciador de Tarefas</h1>
    <div class="d-flex gap-2 flex-wrap">
        <a href="/calendar@(orgId.HasValue ? $"?orgId={orgId}" : "")" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-calendar3"></i>
            <span class="d-none d-sm-inline"> Calendário</span>
        </a>
        <button class="btn @(treeView ? "btn-secondary" : "btn-outline-secondary") btn-sm"
                @onclick="() => { treeView = !treeView; BuildTree(); }">
            <i class="bi bi-diagram-3"></i>
            <span class="d-none d-sm-inline"> </span>@(treeView ? "Lista" : "Árvore")
        </button>
        <a href="@(orgId.HasValue ? $"add-task?orgId={orgId}" : "add-task")" class="btn btn-success btn-sm">
            <i class="bi bi-plus-circle"></i> Nova Tarefa
        </a>
    </div>
</div>

@if (orgId.HasValue)
{
    <div class="alert alert-primary d-flex justify-content-between align-items-center py-2 mb-3">
        <span>🏢 Exibindo tasks de <strong>@orgName</strong></span>
        <a href="/org/@orgId" class="btn btn-sm btn-outline-primary">Ver Painel da Org</a>
    </div>
}

<!-- FILTROS -->
<div class="card mb-4">
    <div class="card-header">
        <h5 class="mb-0"><i class="bi bi-funnel"></i> Filtros</h5>
    </div>
    <div class="card-body">
        <div class="row g-2">
            <div class="col-6 col-md-2">
                <label class="form-label form-label-sm">Categoria</label>
                <select class="form-select form-select-sm" @bind="filter.Category" @bind:after="ApplyFilters">
                    <option value="">Todas</option>
                    @foreach (var cat in availableCategories)
                    {
                        <option value="@cat">@cat</option>
                    }
                </select>
            </div>
            <div class="col-6 col-md-2">
                <label class="form-label form-label-sm">Tag</label>
                <select class="form-select form-select-sm" @bind="filter.Tag" @bind:after="ApplyFilters">
                    <option value="">Todas</option>
                    @foreach (var tag in availableTags)
                    {
                        <option value="@tag">@tag</option>
                    }
                </select>
            </div>
            <div class="col-6 col-md-2">
                <label class="form-label form-label-sm">Status</label>
                <select class="form-select form-select-sm" @bind="statusFilter" @bind:after="ApplyFilters">
                    <option value="">Todos</option>
                    <option value="pending">Pendentes</option>
                    <option value="completed">Concluídas</option>
                </select>
            </div>
            <div class="col-6 col-md-2">
                <label class="form-label form-label-sm">Vencimento</label>
                <select class="form-select form-select-sm" @bind="filter.DueDateRange" @bind:after="ApplyFilters">
                    <option value="">Qualquer</option>
                    <option value="today">Hoje</option>
                    <option value="week">7 dias</option>
                    <option value="overdue">Atrasadas</option>
                </select>
            </div>
            <div class="col-6 col-md-2">
                <label class="form-label form-label-sm">Ordenar por</label>
                <select class="form-select form-select-sm" @bind="filter.SortBy" @bind:after="ApplyFilters">
                    <option value="priority">Prioridade</option>
                    <option value="duedate">Vencimento</option>
                    <option value="created">Criação</option>
                </select>
            </div>
            <div class="col-6 col-md-2">
                <label class="form-label form-label-sm">Prioridade máx.</label>
                <input type="number" class="form-control form-control-sm" min="1" max="100" @bind="filter.MaxPriority"
                       @bind:after="ApplyFilters" />
            </div>
        </div>

        <!-- Checkboxes -->
        <div class="d-flex flex-wrap gap-3 mt-3">
            <div class="form-check">
                <input class="form-check-input" type="checkbox" id="chkAssigned" @bind="filterAssignedToMe"
                       @bind:after="ApplyFilters" />
                <label class="form-check-label" for="chkAssigned">👤 Atribuídas a mim</label>
            </div>
            <div class="form-check">
                <input class="form-check-input" type="checkbox" id="chkReview" @bind="filterNeedsMyReview"
                       @bind:after="ApplyFilters" />
                <label class="form-check-label" for="chkReview">🔍 Aguardando revisão</label>
            </div>
            <div class="form-check">
                <input class="form-check-input" type="checkbox" id="chkMine" @bind="filterCreatedByMe"
                       @bind:after="ApplyFilters" />
                <label class="form-check-label" for="chkMine">✏️ Criadas por mim</label>
            </div>
            <div class="form-check">
                <input class="form-check-input" type="checkbox" id="chkBlocked" @bind="filterBlocked"
                       @bind:after="ApplyFilters" />
                <label class="form-check-label" for="chkBlocked">⛔ Bloqueadas</label>
            </div>
            <button class="btn btn-outline-secondary btn-sm ms-auto" @onclick="ClearFilters">
                ✕ Limpar
            </button>
        </div>

        <div class="mt-2">
            <small class="text-muted">
                @filteredTasks.Count resultado(s) de @allTasks.Count tarefas
                @if (totalPages > 1)
                {
                    <span>· página @currentPage de @totalPages</span>
                }
            </small>
        </div>
    </div>
</div>

@if (isLoading)
{
    <div class="spinner-border" role="status">
        <span class="visually-hidden">Carregando...</span>
    </div>
}
else if (!filteredTasks.Any())
{
    <div class="alert alert-info">
        <h5>Nenhuma tarefa encontrada</h5>
        @if (IsFilterActive())
        {
            <button class="btn btn-link p-0" @onclick="ClearFilters">Limpar filtros</button>
        }
        else
        {
            <a href="/add-task" class="btn btn-primary">Criar Primeira Tarefa</a>
        }
    </div>
}
else if (treeView)
{
    <!-- ÁRVORE DE DEPENDÊNCIAS -->
    <div class="tree-view mb-4">
        @foreach (var node in treeNodes)
        {
            @RenderTreeNode(node, 0)
        }
    </div>
}
else
{
    @foreach (var task in pagedTasks)
    {
        <div class="card mb-3 @(task.IsCompleted ? "border-success opacity-75" : "")">
            <div class="card-header d-flex justify-content-between align-items-start">
                <div class="d-flex align-items-center gap-2">
                    @{
                        var _canComplete = !taskCanComplete.TryGetValue(task.Id, out var _cp) || _cp;
                        var _blocked = pendingDependencies.Contains(task.Id);
                    }
                    <input type="checkbox" class="form-check-input mt-0" checked="@task.IsCompleted"
                           disabled="@(_blocked || !_canComplete)" @onchange="() => ToggleComplete(task.Id)"
                           style="width:1.2rem;height:1.2rem;cursor:@((_blocked || !_canComplete) ? "not-allowed" : "pointer");" />
                    <h5 class="mb-0">
                        <a href="/task/@task.Id"
                           class="text-decoration-none @(task.IsCompleted ? "text-decoration-line-through text-muted" : "text-dark")">
                            <span class="text-muted me-1 small">#@task.Id</span> @task.Title
                        </a>
                    </h5>
                </div>
                <span class="badge @(GetPriorityClass(task.Priority)) fs-6">
                    @GetPriorityEmoji(task.Priority) @task.Priority
                </span>
            </div>

            @if (task.DependencyOnTaskIds != null && task.DependencyOnTaskIds.Any())
            {
                <div class="px-3 pt-2">
                    @if (pendingDependencies.Contains(task.Id))
                    {
                        <div class="alert alert-warning py-1 px-2 mb-2 d-flex align-items-center gap-2">
                            ⚠️ Depende de tarefas pendentes:
                            @foreach (var depId in task.DependencyOnTaskIds)
                            {
                                <a href="/task/@depId" class="badge bg-warning text-dark text-decoration-none ms-1">#@depId</a>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="d-flex align-items-center gap-1 mb-2 flex-wrap">
                            <small class="text-muted">🔗 Depende de:</small>
                            @foreach (var depId in task.DependencyOnTaskIds)
                            {
                                <a href="/task/@depId" class="badge bg-secondary text-decoration-none ms-1">#@depId</a>
                            }
                        </div>
                    }
                </div>
            }

            <div class="card-body">
                @if (!string.IsNullOrEmpty(task.Description))
                {
                    <p class="card-text">@task.Description</p>
                }
                <div class="d-flex flex-wrap gap-2 text-muted small">
                    @if (!string.IsNullOrEmpty(task.Category))
                    {
                        <span><strong>@task.Category</strong></span>
                    }
                    @if (task.Tags?.Any() == true)
                    {
                        <span>
                            @foreach (var tag in task.Tags.Take(3))
                            {
                                <span class="badge bg-secondary ms-1">@tag</span>
                            }
                            @if (task.Tags.Count > 3)
                            {
                                <span class="text-muted">+@(task.Tags.Count - 3)</span>
                            }
                        </span>
                    }
                    @if (task.DueDate.HasValue)
                    {
                        <span>
                            Vence @task.DueDate.Value.ToLocalTime().ToString("dd/MM")
                            @if (task.DueDate.Value < DateTime.Now && !task.IsCompleted)
                            {
                                <span class="badge bg-danger ms-1">Atrasada</span>
                            }
                        </span>
                    }
                    @if (task.AssignedToUserIds?.Any() == true)
                    {
                        <span>
                            👤
                            @foreach (var uid in task.AssignedToUserIds.Take(2))
                            {
                                <span class="badge bg-primary ms-1">@uid[..8]</span>
                            }
                            @if (task.AssignedToUserIds.Count > 2)
                            {
                                <span class="badge bg-secondary ms-1">+@(task.AssignedToUserIds.Count - 2)</span>
                            }
                        </span>
                    }
                    @if (task.NeedsReview > 0 && task.ReviewByUserId?.Any() == true)
                    {
                        var reviewed = task.ReviewedByUserId?.Count ?? 0;
                        var reviewComplete = reviewed >= task.NeedsReview;
                        <span>
                            @if (reviewComplete)
                            {
                                <span class="badge bg-success">✅ Revisão completa</span>
                            }
                            else if (task.ReviewByUserId.Contains(currentUserId ?? ""))
                            {
                                <span class="badge bg-warning text-dark">🔍 Sua revisão pendente</span>
                            }
                            else
                            {
                                <span class="badge bg-info text-dark">🔍 @reviewed/@task.NeedsReview revisões</span>
                            }
                        </span>
                    }
                    <span class="ms-auto">Criada: @task.CreatedAt.ToString("dd/MM/yy")</span>
                </div>
                @if (task.Comments?.Any() == true)
                {
                    <div class="mt-2">
                        <small>@task.Comments.Count comentário@(task.Comments.Count > 1 ? "s" : "")</small>
                    </div>
                }
            </div>
            <div class="card-footer text-end">
                @if (!taskCanEdit.TryGetValue(task.Id, out var _canEdit) || _canEdit)
                {
                    <a href="/edit-task/@task.Id" class="btn btn-outline-primary btn-sm me-2">
                        <i class="bi bi-pencil"></i> Editar
                    </a>
                }
                @if (!taskCanDelete.TryGetValue(task.Id, out var _canDelete) || _canDelete)
                {
                    <button class="btn btn-outline-danger btn-sm" @onclick="() => ShowDeleteConfirm(task.Id)">
                        <i class="bi bi-trash"></i> Excluir
                    </button>
                }
            </div>
        </div>
    }
}

<!-- Paginação -->
@if (!isLoading && filteredTasks.Any())
{
    <div class="d-flex justify-content-between align-items-center mt-3 mb-4">
        <div class="d-flex align-items-center gap-2">
            <small class="text-muted">Por página:</small>
            <select class="form-select form-select-sm" style="width:80px;" @bind="pageSize"
                    @bind:after="() => currentPage = 1">
                <option value="10">10</option>
                <option value="20">20</option>
                <option value="50">50</option>
            </select>
            <small class="text-muted ms-2">
                @((currentPage - 1) * pageSize + 1)–@(Math.Min(currentPage * pageSize, filteredTasks.Count))
                de @filteredTasks.Count
            </small>
        </div>
        <nav>
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                    <button class="page-link" @onclick="() => currentPage--" disabled="@(currentPage == 1)">
                        <i class="bi bi-chevron-left"></i>
                    </button>
                </li>
                @for (var p = Math.Max(1, currentPage - 2); p <= Math.Min(totalPages, currentPage + 2); p++)
                {
                    var pg = p;
                    <li class="page-item @(pg == currentPage ? "active" : "")">
                        <button class="page-link" @onclick="() => currentPage = pg">@pg</button>
                    </li>
                }
                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                    <button class="page-link" @onclick="() => currentPage++" disabled="@(currentPage == totalPages)">
                        <i class="bi bi-chevron-right"></i>
                    </button>
                </li>
            </ul>
        </nav>
    </div>
}

@if (showDeleteConfirm)
{
    <div class="modal show d-block" tabindex="-1" style="background-color:rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirmar exclusão</h5>
                    <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                </div>
                <div class="modal-body">
                    <p>Tem certeza que deseja excluir esta tarefa? Esta ação não pode ser desfeita.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CancelDelete">Cancelar</button>
                    <button type="button" class="btn btn-danger" @onclick="ConfirmDelete">Excluir</button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .tree-view {}

    .tree-node {
        border-left: 2px solid #dee2e6;
        padding-left: 8px;
        margin-bottom: 4px;
    }

    .tree-node:last-child {
        margin-bottom: 0;
    }

    .tree-node-done {
        opacity: 0.6;
    }

    .tree-node-header {
        background: white;
        border: 1px solid #dee2e6;
        border-radius: 6px;
        padding: 6px 10px;
        transition: background 0.1s;
    }

    .tree-node-header:hover {
        background: #f8f9fa;
    }

    .tree-toggle {
        color: #6c757d;
        text-decoration: none;
        line-height: 1;
        width: 18px;
        flex-shrink: 0;
    }

    .tree-toggle:hover {
        color: #0d6efd;
    }

    .tree-leaf-spacer {
        display: inline-block;
        width: 18px;
        flex-shrink: 0;
    }

    .tree-children {
        margin-top: 4px;
        padding-left: 0;
    }
</style>

@code {
    private List<TaskItem> allTasks = new();
    private List<TaskItem> filteredTasks = new();
    private List<string> availableCategories = new();
    private List<string> availableTags = new();

    private TaskFilter filter = new();
    private string statusFilter = "";

    private HashSet<int> pendingDependencies = new();
    private int? orgId;
    private string? orgName;
    private string? currentUserId;
    private bool isLoading = true;
    private bool showDeleteConfirm = false;
    private int taskToDeleteId = 0;
    private bool filterAssignedToMe = false;
    private bool filterNeedsMyReview = false;
    private bool filterCreatedByMe = false;
    private bool filterBlocked = false;
    private int? lastOrgId;
    private Dictionary<int, bool> taskCanDelete = new();
    // Visualização em árvore
    private bool treeView = false;
    private record TreeNode(TaskItem Task, List<TreeNode> Children);
    private List<TreeNode> treeNodes = new();
    private HashSet<int> collapsedNodes = new();
    // Paginação
    private int currentPage = 1;
    private int pageSize = 10;
    private int totalPages => (int)Math.Ceiling((double)filteredTasks.Count / pageSize);
    private List<TaskItem> pagedTasks => filteredTasks
        .Skip((currentPage - 1) * pageSize)
        .Take(pageSize)
        .ToList();
    private Dictionary<int, bool> taskCanEdit = new();
    private Dictionary<int, bool> taskCanComplete = new();


    protected override async Task OnInitializedAsync()
    {
        Nav.LocationChanged += OnLocationChanged;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        currentUserId = authState.User.FindFirst(
            System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        await LoadFromUrl();
        isLoading = false;
    }

    private async Task LoadFromUrl()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);

        int? newOrgId = null;
        if (query.TryGetValue("orgId", out var orgIdStr) && int.TryParse(orgIdStr, out var parsed))
            newOrgId = parsed;

        orgId = newOrgId;

        if (orgId.HasValue)
        {
            var org = await OrgService.GetOrganizationByIdAsync(orgId.Value);
            orgName = org?.Name ?? $"Org #{orgId}";
        }
        else
        {
            orgName = null;
        }

        allTasks = await TaskService.GetAllTasksAsync(currentUserId, orgId);

        availableCategories = allTasks
            .Select(t => t.Category)
            .Where(c => !string.IsNullOrEmpty(c))
            .Distinct().OrderBy(c => c).ToList();

        availableTags = allTasks
            .SelectMany(t => t.Tags ?? new List<string>())
            .Where(t => !string.IsNullOrEmpty(t))
            .Distinct().OrderBy(t => t).ToList();

        await LoadPendingDependencies();
        await LoadTaskPermissions();
        ApplyFilters();
    }

    private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        await LoadFromUrl();
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
    }


    private async Task LoadTaskPermissions()
    {
        taskCanDelete.Clear();
        taskCanEdit.Clear();
        taskCanComplete.Clear();

        foreach (var t in allTasks)
        {
            if (t.OrganizationId.HasValue)
            {
                var org = await OrgService.GetOrganizationByIdAsync(t.OrganizationId.Value);
                var role = await OrgService.GetUserRoleAsync(t.OrganizationId.Value, currentUserId!);
                if (org != null && role.HasValue)
                {
                    taskCanDelete[t.Id] = OrgService.CanDeleteTask(org, role.Value);
                    taskCanEdit[t.Id] = OrgService.CanEditTask(org, role.Value);
                    // Assignees always can complete regardless of policy
                    var isAssignee = t.AssignedToUserIds?.Contains(currentUserId ?? "") == true;
                    taskCanComplete[t.Id] = isAssignee || OrgService.CanCompleteTask(org, role.Value);
                }
                else
                {
                    taskCanDelete[t.Id] = taskCanEdit[t.Id] = taskCanComplete[t.Id] = false;
                }
            }
            else
            {
                // Task pessoal — só o autor edita/deleta; autor ou assignee conclui
                taskCanEdit[t.Id] = t.AuthorUserId == currentUserId;
                taskCanDelete[t.Id] = t.AuthorUserId == currentUserId;
                taskCanComplete[t.Id] = t.AuthorUserId == currentUserId
                                        || (t.AssignedToUserIds?.Contains(currentUserId ?? "") == true);
            }
        }
    }

    private void BuildTree()
    {
        var filteredIds = filteredTasks.Select(t => t.Id).ToHashSet();

        // IDs that appear as a dependency of someone — they are children, not roots
        var appearsAsChild = filteredTasks
            .Where(t => t.DependencyOnTaskIds != null)
            .SelectMany(t => t.DependencyOnTaskIds!)
            .Where(id => filteredIds.Contains(id))
            .ToHashSet();

        // Roots = tasks NOT appearing as a child of anyone in the filtered list
        // This includes: tasks with children, AND standalone tasks with no dependencies
        var roots = filteredTasks
            .Where(t => !appearsAsChild.Contains(t.Id))
            .OrderBy(t => t.Priority)
            .ToList();

        treeNodes = roots.Select(r => BuildNode(r)).ToList();
    }

    private TreeNode BuildNode(TaskItem task)
    {
        var filteredIds = filteredTasks.Select(t => t.Id).ToHashSet();

        // Children = tasks that THIS task depends on (must be done before this task)
        // A task can appear as child in multiple trees
        var children = (task.DependencyOnTaskIds ?? new List<int>())
            .Where(id => filteredIds.Contains(id))
            .Select(id => filteredTasks.First(t => t.Id == id))
            .OrderBy(t => t.Priority)
            .Select(c => BuildNode(c))
            .ToList();

        return new TreeNode(task, children);
    }

    private RenderFragment RenderTreeNode(TreeNode node, int depth) => __builder =>
    {
        var task = node.Task;
        var hasChildren = node.Children.Any();
        var isCollapsed = collapsedNodes.Contains(task.Id);
        var indent = depth * 28;

        var _canComplete = !taskCanComplete.TryGetValue(task.Id, out var _cp) || _cp;
        var _blocked = pendingDependencies.Contains(task.Id);

        <div class="tree-node @(task.IsCompleted ? "tree-node-done" : "")" style="margin-left: @(indent)px;">
            <div class="tree-node-header d-flex align-items-center gap-2">
                @if (hasChildren)
                {
                    <button class="btn btn-link p-0 tree-toggle" @onclick="() => ToggleNode(task.Id)"
                            @onclick:stopPropagation="true">
                        <i class="bi @(isCollapsed ? "bi-chevron-right" : "bi-chevron-down") small"></i>
                    </button>
                }
                else
                {
                    <span class="tree-leaf-spacer"></span>
                }

                <input type="checkbox" class="form-check-input mt-0 flex-shrink-0" checked="@task.IsCompleted"
                       disabled="@(_blocked || !_canComplete)" @onchange="() => ToggleComplete(task.Id)"
                       style="width:1.1rem;height:1.1rem;cursor:@((_blocked || !_canComplete) ? "not-allowed" : "pointer");" />

                <a href="/task/@task.Id"
                   class="flex-grow-1 text-decoration-none @(task.IsCompleted ? "text-muted text-decoration-line-through" : "text-dark") fw-semibold small">
                    <span class="text-muted me-1">#@task.Id</span>@task.Title
                </a>

                <span class="badge @GetPriorityClass(task.Priority) ms-1">
                    @GetPriorityEmoji(task.Priority) @task.Priority
                </span>

                @if (task.DueDate.HasValue)
                {
                    var overdue = task.DueDate.Value < DateTime.Now && !task.IsCompleted;
                    <span class="badge @(overdue ? "bg-danger" : "bg-light text-dark border") small">
                        @task.DueDate.Value.ToLocalTime().ToString("dd/MM")
                    </span>
                }

                <span class="badge bg-light text-dark border small">@task.Category</span>

                @if (!taskCanEdit.TryGetValue(task.Id, out var _canEdit) || _canEdit)
                {
                    <a href="/edit-task/@task.Id" class="btn btn-outline-primary btn-sm py-0 px-1">
                        <i class="bi bi-pencil"></i>
                    </a>
                }
                @if (!taskCanDelete.TryGetValue(task.Id, out var _canDelete) || _canDelete)
                {
                    <button class="btn btn-outline-danger btn-sm py-0 px-1" @onclick="() => ShowDeleteConfirm(task.Id)">
                        <i class="bi bi-trash"></i>
                    </button>
                }
            </div>

            @if (hasChildren && !isCollapsed)
            {
                <div class="tree-children">
                    @foreach (var child in node.Children)
                    {
                        @RenderTreeNode(child, depth + 1)
                    }
                </div>
            }
        </div>
    };

    private void ToggleNode(int taskId)
    {
        if (!collapsedNodes.Add(taskId))
            collapsedNodes.Remove(taskId);
    }

    private void ApplyFilters()
    {
        var result = allTasks.AsEnumerable();

        if (!string.IsNullOrEmpty(filter.Category))
            result = result.Where(t => t.Category == filter.Category);

        if (!string.IsNullOrEmpty(filter.Tag))
            result = result.Where(t => t.Tags != null && t.Tags.Contains(filter.Tag));

        if (!string.IsNullOrEmpty(statusFilter))
            result = result.Where(t => statusFilter == "pending" ? !t.IsCompleted : t.IsCompleted);

        if (!string.IsNullOrEmpty(filter.DueDateRange))
        {
            var today = DateTime.Now.Date;
            result = filter.DueDateRange switch
            {
                "today" => result.Where(t => t.DueDate.HasValue && t.DueDate.Value.ToLocalTime().Date == today),
                "week" => result.Where(t => t.DueDate.HasValue && t.DueDate.Value.ToLocalTime().Date >= today &&
t.DueDate.Value.ToLocalTime().Date <= today.AddDays(7)),
                "overdue" => result.Where(t => t.DueDate.HasValue && t.DueDate.Value.ToLocalTime().Date < today && !t.IsCompleted),
                _ => result
            };
        }
        if (filterAssignedToMe)
            result = result.Where(t => t.AssignedToUserIds != null && t.AssignedToUserIds.Contains(currentUserId ?? ""));

        if (filterNeedsMyReview)
            result = result.Where(t => t.ReviewByUserId != null &&
                                       t.ReviewByUserId.Contains(currentUserId ?? "") &&
                                       !(t.ReviewedByUserId ?? new()).Contains(currentUserId ?? ""));

        if (filterCreatedByMe)
            result = result.Where(t => t.AuthorUserId == currentUserId);

        if (filter.MaxPriority.HasValue)
            result = result.Where(t => t.Priority <= filter.MaxPriority.Value);

        if (filterBlocked)
            result = result.Where(t => pendingDependencies.Contains(t.Id));

        result = filter.SortBy switch
        {
            "duedate" => result.OrderBy(t => t.DueDate == null).ThenBy(t => t.DueDate),
            "created" => result.OrderByDescending(t => t.CreatedAt),
            _ => result.OrderBy(t => t.Priority).ThenBy(t => t.CreatedAt)
        };

        filteredTasks = result.ToList();
        currentPage = 1; // reset to first page on filter change
        BuildTree();
    }

    private void ClearFilters()
    {
        filter = new TaskFilter();
        statusFilter = "";
        filterAssignedToMe = false;
        filterNeedsMyReview = false;
        filterCreatedByMe = false;
        filterBlocked = false;
        filter.MaxPriority = null;
        ApplyFilters();
    }

    private bool IsFilterActive() =>
        !string.IsNullOrEmpty(filter.Category) ||
        !string.IsNullOrEmpty(filter.Tag) ||
        !string.IsNullOrEmpty(statusFilter) ||
        !string.IsNullOrEmpty(filter.DueDateRange) ||
        filterAssignedToMe ||
        filterNeedsMyReview ||
        filterCreatedByMe ||
        filterBlocked ||
        filter.MaxPriority.HasValue;

    private string GetPriorityEmoji(int p) => p switch { <= 2 => "🔴", <= 5 => "🟠", <= 10 => "🟡", <= 20 => "🟢", _ => "⚪" };
    private string GetPriorityClass(int p) => p switch
    {
        <= 2 => "bg-danger",
        <= 5 => "bg-warning",
        <= 10 => "bg-info",
        _ =>
"bg-success"
    };

    private void ShowDeleteConfirm(int id) { taskToDeleteId = id; showDeleteConfirm = true; }
    private void CancelDelete() { showDeleteConfirm = false; }

    private async Task ConfirmDelete()
    {
        await TaskService.DeleteTaskAsync(taskToDeleteId, currentUserId);
        showDeleteConfirm = false;
        await OnInitializedAsync();
    }

    private async Task ToggleComplete(int id)
    {
        if (pendingDependencies.Contains(id)) return;
        await TaskService.ToggleCompleteAsync(id, currentUserId!);
        allTasks = await TaskService.GetAllTasksAsync(currentUserId, orgId);
        await LoadPendingDependencies();
        ApplyFilters();
    }

    private async Task LoadPendingDependencies()
    {
        pendingDependencies.Clear();
        foreach (var task in allTasks)
        {
            if (await TaskService.HasPendingDependenciesAsync(task.Id))
                pendingDependencies.Add(task.Id);
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        int? newOrgId = null;
        if (query.TryGetValue("orgId", out var orgIdStr) && int.TryParse(orgIdStr, out var parsed))
            newOrgId = parsed;

        if (newOrgId != lastOrgId)
        {
            lastOrgId = newOrgId;
            orgId = newOrgId;

            if (orgId.HasValue)
            {
                var org = await OrgService.GetOrganizationByIdAsync(orgId.Value);
                orgName = org?.Name ?? $"Org #{orgId}";
            }
            else
            {
                orgName = null;
            }

            allTasks = await TaskService.GetAllTasksAsync(currentUserId, orgId);
            await LoadPendingDependencies();
            ApplyFilters();
        }
    }
}