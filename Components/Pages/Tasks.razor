@page "/tasks"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@using TaskManager.Services
@using TaskManager.Models
@using TaskManager.DTOs
@inject TaskService TaskService
@inject NavigationManager Nav
@inject OrganizationService OrgService
@inject AuthenticationStateProvider AuthStateProvider
@rendermode InteractiveServer

<PageTitle>Tarefas</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Gerenciador de Tarefas</h1>
    <a href="@(orgId.HasValue ? $"add-task?orgId={orgId}" : "add-task")" class="btn btn-success">
        <i class="bi bi-plus-circle"></i> Nova Tarefa
    </a>
</div>

@if (orgId.HasValue)
{
    <div class="alert alert-primary d-flex justify-content-between align-items-center py-2 mb-3">
        <span>🏢 Exibindo tasks de <strong>@orgName</strong></span>
        <a href="/org/@orgId" class="btn btn-sm btn-outline-primary">Ver Painel da Org</a>
    </div>
}

<!-- FILTROS -->
<div class="card mb-4">
    <div class="card-header">
        <h5 class="mb-0"><i class="bi bi-funnel"></i> Filtros</h5>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-2">
                <label class="form-label">Categoria</label>
                <select class="form-select" @bind="filter.Category" @bind:after="ApplyFilters">
                    <option value="">Todas</option>
                    @foreach (var cat in availableCategories)
                    {
                        <option value="@cat">@cat</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Tag</label>
                <select class="form-select" @bind="filter.Tag" @bind:after="ApplyFilters">
                    <option value="">Todas</option>
                    @foreach (var tag in availableTags)
                    {
                        <option value="@tag">@tag</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Status</label>
                <select class="form-select" @bind="statusFilter" @bind:after="ApplyFilters">
                    <option value="">Todos</option>
                    <option value="pending">Pendentes</option>
                    <option value="completed">Concluídas</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Vencimento</label>
                <select class="form-select" @bind="filter.DueDateRange" @bind:after="ApplyFilters">
                    <option value="">Qualquer</option>
                    <option value="today">Hoje</option>
                    <option value="week">Próximos 7 dias</option>
                    <option value="overdue">Atrasadas</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Ordenar por</label>
                <select class="form-select" @bind="filter.SortBy" @bind:after="ApplyFilters">
                    <option value="priority">Prioridade</option>
                    <option value="duedate">Vencimento</option>
                    <option value="created">Criação</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Prioridade máxima</label>
                <input type="number" class="form-control" min="1" max="100"                       @bind="filter.MaxPriority"
                       @bind:after="ApplyFilters" />
            </div>
        </div>

        <!-- Checkboxes + Limpar -->
        <div class="row mt-3 text-center">
            <div class="col">
                <input class="form-check-input me-1" type="checkbox" id="chkAssigned"               @bind="filterAssignedToMe"
                       @bind:after="ApplyFilters" />
                <label class="form-check-label" for="chkAssigned">👤 Atribuídas a mim</label>
            </div>
            <div class="col">
                <input class="form-check-input me-1" type="checkbox" id="chkReview"               @bind="filterNeedsMyReview"
                       @bind:after="ApplyFilters" />
                <label class="form-check-label" for="chkReview">🔍 Aguardando minha revisão</label>
            </div>
            <div class="col">
                <input class="form-check-input me-1" type="checkbox" id="chkMine"               @bind="filterCreatedByMe"
                       @bind:after="ApplyFilters" />
                <label class="form-check-label" for="chkMine">✏️ Criadas por mim</label>
            </div>
            <div class="col">
                <input class="form-check-input me-1" type="checkbox" id="chkBlocked"               @bind="filterBlocked"
                       @bind:after="ApplyFilters" />
                <label class="form-check-label" for="chkBlocked">⛔ Bloqueadas</label>
            </div>
            <div class="col-auto">
                <button class="btn btn-outline-secondary btn-sm" @onclick="ClearFilters">✕ Limpar</button>
            </div>
        </div>
        
        <div class="mt-2">
            <small class="text-muted">Mostrando @filteredTasks.Count de @allTasks.Count tarefas</small>
        </div>
    </div>
</div>

@if (isLoading)
{
    <div class="spinner-border" role="status">
        <span class="visually-hidden">Carregando...</span>
    </div>
}
else if (!filteredTasks.Any())
{
    <div class="alert alert-info">
        <h5>Nenhuma tarefa encontrada</h5>
        @if (IsFilterActive())
        {
            <button class="btn btn-link p-0" @onclick="ClearFilters">Limpar filtros</button>
        }
        else
        {
            <a href="/add-task" class="btn btn-primary">Criar Primeira Tarefa</a>
        }
    </div>
}
else
{
    @foreach (var task in filteredTasks)
    {
        <div class="card mb-3 @(task.IsCompleted ? "border-success opacity-75" : "")">
            <div class="card-header d-flex justify-content-between align-items-start">
                <div class="d-flex align-items-center gap-2">
                    <input type="checkbox" class="form-check-input mt-0" checked="@task.IsCompleted"
                           disabled="@(pendingDependencies.Contains(task.Id))" @onchange="() => ToggleComplete(task.Id)"
                           style="width:1.2rem;height:1.2rem;cursor:@(pendingDependencies.Contains(task.Id) ? "not-allowed" : "pointer");" />
                    <h5 class="mb-0">
                        <a href="/task/@task.Id"
                               class="text-decoration-none @(task.IsCompleted ? "text-decoration-line-through text-muted" : "text-dark")">
                            <span class="text-muted me-1 small">#@task.Id</span> @task.Title
                        </a>
                    </h5>
                </div>
                <span class="badge @(GetPriorityClass(task.Priority)) fs-6">
                    @GetPriorityEmoji(task.Priority) @task.Priority
                </span>
            </div>

            @if (task.DependencyOnTaskIds != null && task.DependencyOnTaskIds.Any())
            {
                <div class="px-3 pt-2">
                    @if (pendingDependencies.Contains(task.Id))
                    {
                        <div class="alert alert-warning py-1 px-2 mb-2 d-flex align-items-center gap-2">
                            ⚠️ Depende de tarefas pendentes:
                            @foreach (var depId in task.DependencyOnTaskIds)
                            {
                                <a href="/task/@depId" class="badge bg-warning text-dark text-decoration-none ms-1">#@depId</a>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="d-flex align-items-center gap-1 mb-2 flex-wrap">
                            <small class="text-muted">🔗 Depende de:</small>
                            @foreach (var depId in task.DependencyOnTaskIds)
                            {
                                <a href="/task/@depId" class="badge bg-secondary text-decoration-none ms-1">#@depId</a>
                            }
                        </div>
                    }
                </div>
            }

            <div class="card-body">
                @if (!string.IsNullOrEmpty(task.Description))
                {
                    <p class="card-text">@task.Description</p>
                }
                <div class="row text-muted small">
                    <div class="col-md-3"><strong>@task.Category</strong></div>
                    <div class="col-md-3">
                        Tags:
                        @foreach (var tag in task.Tags.Take(3))
                        {
                            <span class="badge bg-secondary ms-1">@tag</span>
                        }
                        @if (task.Tags.Count > 3)
                        {
                            <span class="text-muted">+@(task.Tags.Count - 3)</span>
                        }
                    </div>
                    @if (task.DueDate.HasValue)
                    {
                        <div class="col-md-3">
                            Vence @task.DueDate.Value.ToLocalTime().ToString("dd/MM")
                            @if (task.DueDate.Value < DateTime.Now && !task.IsCompleted)
                            {
                                <span class="badge bg-danger ms-1">Atrasada</span>
                            }
                        </div>
                    }
                    @if (task.AssignedToUserIds?.Any() == true)
                    {
                        <div class="col-md-3">
                            <span class="text-muted small">👤 </span>
                            @foreach (var uid in task.AssignedToUserIds.Take(3))
                            {
                                <span class="badge bg-primary ms-1 small">@uid[..8]</span>
                            }
                            @if (task.AssignedToUserIds.Count > 3)
                            {
                                <span class="badge bg-secondary ms-1 small">+@(task.AssignedToUserIds.Count - 3)</span>
                            }
                        </div>
                    }
                    @if (task.NeedsReview > 0 && task.ReviewByUserId?.Any() == true)
                    {
                        var reviewed = task.ReviewedByUserId?.Count ?? 0;
                        var reviewComplete = reviewed >= task.NeedsReview;
                        <div class="col-md-3">
                            @if (reviewComplete)
                            {
                                <span class="badge bg-success small">✅ Revisão completa</span>
                            }
                            else if (task.ReviewByUserId.Contains(currentUserId ?? ""))
                            {
                                <span class="badge bg-warning text-dark small">🔍 Sua revisão pendente</span>
                            }
                            else
                            {
                                <span class="badge bg-info text-dark small">🔍 @reviewed/@task.NeedsReview revisões</span>
                            }
                        </div>
                    }
                    <div class="col-md-3">Criada: @task.CreatedAt.ToString("dd/MM/yy HH:mm")</div>
                </div>
                @if (task.Comments?.Any() == true)
                {
                    <div class="mt-2">
                        <small>@task.Comments.Count comentário@(task.Comments.Count > 1 ? "s" : "")</small>
                    </div>
                }
            </div>
            <div class="card-footer text-end">
                <a href="/edit-task/@task.Id" class="btn btn-outline-primary btn-sm me-2">
                    <i class="bi bi-pencil"></i> Editar
                </a>
                <button class="btn btn-outline-danger btn-sm" @onclick="() => ShowDeleteConfirm(task.Id)">
                    <i class="bi bi-trash"></i> Excluir
                </button>
            </div>
        </div>
    }
}

@if (showDeleteConfirm)
{
    <div class="modal show d-block" tabindex="-1" style="background-color:rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirmar exclusão</h5>
                    <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                </div>
                <div class="modal-body">
                    <p>Tem certeza que deseja excluir esta tarefa? Esta ação não pode ser desfeita.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CancelDelete">Cancelar</button>
                    <button type="button" class="btn btn-danger" @onclick="ConfirmDelete">Excluir</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<TaskItem> allTasks = new();
    private List<TaskItem> filteredTasks = new();
    private List<string> availableCategories = new();
    private List<string> availableTags = new();

    private TaskFilter filter = new();
    private string statusFilter = "";

    private HashSet<int> pendingDependencies = new();
    private int? orgId;
    private string? orgName;
    private string? currentUserId;
    private bool isLoading = true;
    private bool showDeleteConfirm = false;
    private int taskToDeleteId = 0;
    private bool filterAssignedToMe = false;
    private bool filterNeedsMyReview = false;
    private bool filterCreatedByMe = false;
    private bool filterBlocked = false;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        currentUserId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        if (query.TryGetValue("orgId", out var orgIdStr) && int.TryParse(orgIdStr, out var parsedOrgId))
            orgId = parsedOrgId;

        if (orgId.HasValue)
        {
            var org = await OrgService.GetOrganizationByIdAsync(orgId.Value);
            orgName = org?.Name ?? $"Org #{orgId}";
        }

        allTasks = await TaskService.GetAllTasksAsync(currentUserId, orgId);

        availableCategories = allTasks
            .Select(t => t.Category)
            .Where(c => !string.IsNullOrEmpty(c))
            .Distinct().OrderBy(c => c).ToList();

        availableTags = allTasks
            .SelectMany(t => t.Tags ?? new List<string>())
            .Where(t => !string.IsNullOrEmpty(t))
            .Distinct().OrderBy(t => t).ToList();

        await LoadPendingDependencies();
        ApplyFilters();
        isLoading = false;
    }

    private void ApplyFilters()
    {
        var result = allTasks.AsEnumerable();

        if (!string.IsNullOrEmpty(filter.Category))
            result = result.Where(t => t.Category == filter.Category);

        if (!string.IsNullOrEmpty(filter.Tag))
            result = result.Where(t => t.Tags != null && t.Tags.Contains(filter.Tag));

        if (!string.IsNullOrEmpty(statusFilter))
            result = result.Where(t => statusFilter == "pending" ? !t.IsCompleted : t.IsCompleted);

        if (!string.IsNullOrEmpty(filter.DueDateRange))
        {
            var today = DateTime.Now.Date;
            result = filter.DueDateRange switch
            {
                "today" => result.Where(t => t.DueDate.HasValue && t.DueDate.Value.ToLocalTime().Date == today),
                "week" => result.Where(t => t.DueDate.HasValue && t.DueDate.Value.ToLocalTime().Date >= today &&
t.DueDate.Value.ToLocalTime().Date <= today.AddDays(7)),
                "overdue" => result.Where(t => t.DueDate.HasValue && t.DueDate.Value.ToLocalTime().Date < today && !t.IsCompleted),
                _ => result
            };
        }
        if (filterAssignedToMe)
            result = result.Where(t => t.AssignedToUserIds != null && t.AssignedToUserIds.Contains(currentUserId ?? ""));

        if (filterNeedsMyReview)
            result = result.Where(t => t.ReviewByUserId != null &&
                                       t.ReviewByUserId.Contains(currentUserId ?? "") &&
                                       !(t.ReviewedByUserId ?? new()).Contains(currentUserId ?? ""));

        if (filterCreatedByMe)
            result = result.Where(t => t.AuthorUserId == currentUserId);

        if (filter.MaxPriority.HasValue)
            result = result.Where(t => t.Priority <= filter.MaxPriority.Value);

        if (filterBlocked)
            result = result.Where(t => pendingDependencies.Contains(t.Id));

        result = filter.SortBy switch
        {
            "duedate" => result.OrderBy(t => t.DueDate == null).ThenBy(t => t.DueDate),
            "created" => result.OrderByDescending(t => t.CreatedAt),
            _ => result.OrderBy(t => t.Priority).ThenBy(t => t.CreatedAt)
        };

        filteredTasks = result.ToList();
    }

    private void ClearFilters()
    {
        filter = new TaskFilter();
        statusFilter = "";
        filterAssignedToMe = false;
        filterNeedsMyReview = false;
        filterCreatedByMe = false;
        filterBlocked = false;
        filter.MaxPriority = null;
        ApplyFilters();
    }

    private bool IsFilterActive() =>
        !string.IsNullOrEmpty(filter.Category) ||
        !string.IsNullOrEmpty(filter.Tag) ||
        !string.IsNullOrEmpty(statusFilter) ||
        !string.IsNullOrEmpty(filter.DueDateRange) ||
        filterAssignedToMe ||
        filterNeedsMyReview ||
        filterCreatedByMe ||
        filterBlocked ||
        filter.MaxPriority.HasValue;

    private string GetPriorityEmoji(int p) => p switch { <= 2 => "🔴", <= 5 => "🟠", <= 10 => "🟡", <= 20 => "🟢", _ => "⚪" };
    private string GetPriorityClass(int p) => p switch
    {
        <= 2 => "bg-danger",
        <= 5 => "bg-warning",
        <= 10 => "bg-info",
        _ =>
"bg-success"
    };

    private void ShowDeleteConfirm(int id) { taskToDeleteId = id; showDeleteConfirm = true; }
    private void CancelDelete() { showDeleteConfirm = false; }

    private async Task ConfirmDelete()
    {
        await TaskService.DeleteTaskAsync(taskToDeleteId);
        showDeleteConfirm = false;
        await OnInitializedAsync();
    }

    private async Task ToggleComplete(int id)
    {
        if (pendingDependencies.Contains(id)) return;
        await TaskService.ToggleCompleteAsync(id);
        allTasks = await TaskService.GetAllTasksAsync(currentUserId, orgId);
        await LoadPendingDependencies();
        ApplyFilters();
    }

    private async Task LoadPendingDependencies()
    {
        pendingDependencies.Clear();
        foreach (var task in allTasks)
        {
            if (await TaskService.HasPendingDependenciesAsync(task.Id))
                pendingDependencies.Add(task.Id);
        }
    }
}